---
// AccessibilityWidget.astro - WCAG 2.1 Accessibility Tool Panel
---

<!-- Toggle Button -->
<button 
  id="a11y-toggle" 
  aria-label="Abrir herramientas de accesibilidad"
  title="Herramientas de Accesibilidad"
  class="fixed bottom-6 left-6 z-[9998] w-14 h-14 rounded-full bg-academic-accent text-academic-dark shadow-2xl shadow-academic-accent/40 flex items-center justify-center hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-4 focus:ring-academic-accent/50"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7" aria-hidden="true">
    <circle cx="12" cy="4" r="2"/>
    <path d="M19 10h-6l-1-4H8a1 1 0 000 2h3.3l.7 2.8-2.1 5.6A1 1 0 0011 18a1 1 0 00.94-.66L14 11.5l1 3.5H18a1 1 0 000-2h-2l-.7-2.5H19a1 1 0 000-2z"/>
    <path d="M9.1 13.5L7.3 19a1 1 0 001.88.7L11 14.7z"/>
  </svg>
</button>

<!-- Accessibility Panel -->
<aside 
  id="a11y-panel"
  role="dialog"
  aria-label="Herramientas de Accesibilidad"
  aria-modal="false"
  class="fixed bottom-0 left-0 z-[9997] h-screen w-80 max-w-[90vw] bg-[#0d1117] border-r border-white/10 shadow-2xl overflow-y-auto translate-x-[-100%] transition-transform duration-500 ease-in-out flex flex-col"
>
  <!-- Header -->
  <div class="flex items-center justify-between p-6 border-b border-white/10 sticky top-0 bg-[#0d1117] z-10">
    <div>
      <p class="text-academic-accent text-xs font-black tracking-[0.2em] uppercase mb-1">WCAG 2.1</p>
      <h2 class="font-serif text-xl font-black text-white">Accesibilidad</h2>
    </div>
    <button 
      id="a11y-close" 
      aria-label="Cerrar panel de accesibilidad"
      class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:border-white/30 transition-all"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col gap-8 pb-24">

    <!-- Visual Filters -->
    <div>
      <p class="text-xs font-black tracking-[0.2em] uppercase text-academic-accent mb-5">Filtros Visuales</p>
      <div class="grid grid-cols-3 gap-3">
        
        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="high-contrast" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 3v18M12 3a9 9 0 010 18"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Alto Contraste</span>
        </button>

        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="negative" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a9 9 0 100 18A9 9 0 0012 3z"/><path stroke-linecap="round" d="M12 7v10M9 9l6 6M9 15l6-6"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Negativo</span>
        </button>

        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="grayscale" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M8.5 8.5a5 5 0 007 7"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Escala de Gris</span>
        </button>

        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="bw" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M3 12h18"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Blanco y Negro</span>
        </button>

        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="highlight-links" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Marcar Enlaces</span>
        </button>

        <button class="a11y-filter-btn flex flex-col items-center gap-2 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:border-academic-accent/40 transition-all group focus:outline-none focus:ring-2 focus:ring-academic-accent" data-filter="dyslexia" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/70 group-hover:text-academic-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span class="text-xs font-black text-white/60 group-hover:text-white text-center leading-tight">Fuente Dislexia</span>
        </button>

      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/5"></div>

    <!-- Text Size -->
    <div>
      <p class="text-xs font-black tracking-[0.2em] uppercase text-academic-accent mb-5">Tamaño de Texto</p>
      <div class="flex items-center gap-3">
        <button id="font-decrease" aria-label="Reducir tamaño de texto" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">−</button>
        <div class="flex-1 relative h-2 bg-white/10 rounded-full cursor-pointer" id="font-track">
          <div id="font-fill" class="absolute left-0 top-0 h-full bg-academic-accent rounded-full transition-all" style="width:50%"></div>
          <div id="font-thumb" class="absolute top-1/2 -translate-y-1/2 w-5 h-5 bg-white rounded-full shadow-lg border-2 border-academic-accent transition-all" style="left:calc(50% - 10px)"></div>
        </div>
        <button id="font-increase" aria-label="Aumentar tamaño de texto" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">+</button>
      </div>
      <div class="flex justify-between mt-2">
        <span class="text-xs text-white/50 uppercase tracking-wider">Reducir</span>
        <button id="font-reset" class="text-xs text-academic-accent/60 uppercase tracking-wider hover:text-academic-accent transition-colors font-black focus:outline-none">Restablecer</button>
        <span class="text-xs text-white/50 uppercase tracking-wider">Ampliar</span>
      </div>
    </div>

    <!-- Word Spacing -->
    <div>
      <p class="text-xs font-black tracking-[0.2em] uppercase text-academic-accent mb-5">Espaciado de Palabras</p>
      <div class="flex items-center gap-3">
        <button id="word-decrease" aria-label="Reducir espaciado de palabras" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">−</button>
        <div class="flex-1 relative h-2 bg-white/10 rounded-full cursor-pointer" id="word-track">
          <div id="word-fill" class="absolute left-0 top-0 h-full bg-academic-accent rounded-full transition-all" style="width:50%"></div>
          <div id="word-thumb" class="absolute top-1/2 -translate-y-1/2 w-5 h-5 bg-white rounded-full shadow-lg border-2 border-academic-accent transition-all" style="left:calc(50% - 10px)"></div>
        </div>
        <button id="word-increase" aria-label="Aumentar espaciado de palabras" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">+</button>
      </div>
      <div class="flex justify-between mt-2">
        <span class="text-xs text-white/50 uppercase tracking-wider">Reducir</span>
        <button id="word-reset" class="text-xs text-academic-accent/60 uppercase tracking-wider hover:text-academic-accent transition-colors font-black focus:outline-none">Restablecer</button>
        <span class="text-xs text-white/50 uppercase tracking-wider">Ampliar</span>
      </div>
    </div>

    <!-- Letter Spacing -->
    <div>
      <p class="text-xs font-black tracking-[0.2em] uppercase text-academic-accent mb-5">Espaciado de Letras</p>
      <div class="flex items-center gap-3">
        <button id="letter-decrease" aria-label="Reducir espaciado de letras" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">−</button>
        <div class="flex-1 relative h-2 bg-white/10 rounded-full cursor-pointer" id="letter-track">
          <div id="letter-fill" class="absolute left-0 top-0 h-full bg-academic-accent rounded-full transition-all" style="width:50%"></div>
          <div id="letter-thumb" class="absolute top-1/2 -translate-y-1/2 w-5 h-5 bg-white rounded-full shadow-lg border-2 border-academic-accent transition-all" style="left:calc(50% - 10px)"></div>
        </div>
        <button id="letter-increase" aria-label="Aumentar espaciado de letras" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/60 hover:text-academic-accent hover:border-academic-accent/50 transition-all text-lg font-black focus:outline-none focus:ring-2 focus:ring-academic-accent">+</button>
      </div>
      <div class="flex justify-between mt-2">
        <span class="text-xs text-white/50 uppercase tracking-wider">Reducir</span>
        <button id="letter-reset" class="text-xs text-academic-accent/60 uppercase tracking-wider hover:text-academic-accent transition-colors font-black focus:outline-none">Restablecer</button>
        <span class="text-xs text-white/50 uppercase tracking-wider">Ampliar</span>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/5"></div>

    <!-- Reset All -->
    <button 
      id="a11y-reset-all" 
      class="w-full py-3 rounded-full border border-white/10 text-xs font-black tracking-widest uppercase text-white/50 hover:text-white hover:border-white/30 transition-all focus:outline-none focus:ring-2 focus:ring-academic-accent"
    >
      Restablecer Todo
    </button>

  </div>
</aside>

<!-- Backdrop -->
<div id="a11y-backdrop" class="fixed inset-0 bg-black/20 backdrop-blur-[2px] z-[9996] opacity-0 pointer-events-none transition-opacity duration-500"></div>

<style is:global>
  /* === Visual Filter Classes === */
  html.a11y-high-contrast {
    filter: contrast(2) brightness(1.1);
  }
  html.a11y-negative {
    filter: invert(1) hue-rotate(180deg);
  }
  html.a11y-grayscale {
    filter: grayscale(1);
  }
  html.a11y-bw {
    filter: grayscale(1) contrast(1.8);
  }
  html.a11y-highlight-links a {
    outline: 3px solid #f5c842 !important;
    outline-offset: 2px !important;
    text-decoration: underline !important;
    text-decoration-color: #f5c842 !important;
  }
  html.a11y-dyslexia, html.a11y-dyslexia * {
    font-family: 'OpenDyslexic', 'Comic Sans MS', 'Arial', sans-serif !important;
    line-height: 1.8 !important;
  }

  /* Active filter button state */
  .a11y-filter-btn[aria-pressed="true"] {
    border-color: rgb(var(--color-academic-accent) / 0.8) !important;
    background-color: rgb(var(--color-academic-accent) / 0.1) !important;
  }
  .a11y-filter-btn[aria-pressed="true"] svg,
  .a11y-filter-btn[aria-pressed="true"] span {
    color: #f5c842 !important;
  }
</style>

<script is:inline>
  function initA11y() {
    const STORAGE_KEY = 'a11y_prefs';

    // State
    const state = {
      filters: new Set(),
      fontSize: 0,     // steps: -3 to +5
      wordSpacing: 0,  // steps: -3 to +5
      letterSpacing: 0 // steps: -3 to +5
    };

    const STEPS = 8;
    const FONT_STEP_PX = 1;
    const WORD_STEP = 0.05; // em
    const LETTER_STEP = 0.03; // em
    const MIN_STEP = -3;
    const MAX_STEP = 5;

    // DOM refs
    const toggle = document.getElementById('a11y-toggle');
    const panel = document.getElementById('a11y-panel');
    const closeBtn = document.getElementById('a11y-close');
    const backdrop = document.getElementById('a11y-backdrop');
    const filterBtns = document.querySelectorAll('.a11y-filter-btn');
    const resetAll = document.getElementById('a11y-reset-all');
    const html = document.documentElement;

    if (!toggle || !panel) return; // Prevent errors if elements don't exist

    // === Persistence ===
    function savePrefs() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        filters: [...state.filters],
        fontSize: state.fontSize,
        wordSpacing: state.wordSpacing,
        letterSpacing: state.letterSpacing
      }));
    }

    function loadPrefs() {
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
        
        // Filters
        if (saved.filters) {
          saved.filters.forEach(f => {
            state.filters.add(f);
            html.classList.add('a11y-' + f);
            const btn = document.querySelector(`[data-filter="${f}"]`);
            if (btn) btn.setAttribute('aria-pressed', 'true');
          });
        }

        // Font
        if (saved.fontSize) {
          state.fontSize = saved.fontSize;
          html.style.fontSize = `calc(1rem + ${saved.fontSize * FONT_STEP_PX}px)`;
          const pct = ((saved.fontSize - MIN_STEP) / (MAX_STEP - MIN_STEP)) * 100;
          const fill = document.getElementById('font-fill');
          const thumb = document.getElementById('font-thumb');
          if (fill) fill.style.width = pct + '%';
          if (thumb) thumb.style.left = `calc(${pct}% - 10px)`;
        }

        // Word spacing
        if (saved.wordSpacing) {
          state.wordSpacing = saved.wordSpacing;
          document.body.style.wordSpacing = `${saved.wordSpacing * WORD_STEP}em`;
          const pct = ((saved.wordSpacing - MIN_STEP) / (MAX_STEP - MIN_STEP)) * 100;
          const fill = document.getElementById('word-fill');
          const thumb = document.getElementById('word-thumb');
          if (fill) fill.style.width = pct + '%';
          if (thumb) thumb.style.left = `calc(${pct}% - 10px)`;
        }

        // Letter spacing
        if (saved.letterSpacing) {
          state.letterSpacing = saved.letterSpacing;
          document.body.style.letterSpacing = `${saved.letterSpacing * LETTER_STEP}em`;
          const pct = ((saved.letterSpacing - MIN_STEP) / (MAX_STEP - MIN_STEP)) * 100;
          const fill = document.getElementById('letter-fill');
          const thumb = document.getElementById('letter-thumb');
          if (fill) fill.style.width = pct + '%';
          if (thumb) thumb.style.left = `calc(${pct}% - 10px)`;
        }
      } catch (e) {
        console.error('Error loading a11y prefs', e);
      }
    }

    // Load preferences immediately
    loadPrefs();

    // === Panel Open/Close ===
    function openPanel() {
      panel.style.transform = 'translateX(0)';
      backdrop.style.opacity = '1';
      backdrop.style.pointerEvents = 'auto';
      toggle.setAttribute('aria-expanded', 'true');
    }
    function closePanel() {
      panel.style.transform = 'translateX(-100%)';
      backdrop.style.opacity = '0';
      backdrop.style.pointerEvents = 'none';
      toggle.setAttribute('aria-expanded', 'false');
    }

    // Remove old listeners to prevent duplicates on navigation
    const newToggle = toggle.cloneNode(true);
    toggle.parentNode.replaceChild(newToggle, toggle);
    newToggle.addEventListener('click', () => {
      const isOpen = newToggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closePanel() : openPanel();
    });

    closeBtn.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePanel();
    });

    // === Visual Filters ===
    filterBtns.forEach(btn => {
      // Clone to remove old listeners
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        const filter = newBtn.dataset.filter;
        const isActive = newBtn.getAttribute('aria-pressed') === 'true';
        
        const colorFilters = ['high-contrast', 'negative', 'grayscale', 'bw'];
        if (colorFilters.includes(filter)) {
          colorFilters.forEach(f => {
            if (f !== filter) {
              html.classList.remove('a11y-' + f);
              state.filters.delete(f);
              const otherBtn = document.querySelector(`[data-filter="${f}"]`);
              if (otherBtn) otherBtn.setAttribute('aria-pressed', 'false');
            }
          });
        }

        if (isActive) {
          html.classList.remove('a11y-' + filter);
          state.filters.delete(filter);
          newBtn.setAttribute('aria-pressed', 'false');
        } else {
          html.classList.add('a11y-' + filter);
          state.filters.add(filter);
          newBtn.setAttribute('aria-pressed', 'true');
        }
        savePrefs();
      });
    });

    // === Slider helpers ===
    function makeSlider({ decreaseId, increaseId, resetId, fillId, thumbId, getVal, setVal, minStep, maxStep }) {
      const fill = document.getElementById(fillId);
      const thumb = document.getElementById(thumbId);
      const decBtn = document.getElementById(decreaseId);
      const incBtn = document.getElementById(increaseId);
      const resBtn = document.getElementById(resetId);

      if (!fill || !thumb || !decBtn || !incBtn || !resBtn) return;

      function update() {
        const val = getVal();
        const pct = ((val - minStep) / (maxStep - minStep)) * 100;
        fill.style.width = pct + '%';
        thumb.style.left = `calc(${pct}% - 10px)`;
      }

      // Clone buttons
      const newDec = decBtn.cloneNode(true); decBtn.parentNode.replaceChild(newDec, decBtn);
      const newInc = incBtn.cloneNode(true); incBtn.parentNode.replaceChild(newInc, incBtn);
      const newRes = resBtn.cloneNode(true); resBtn.parentNode.replaceChild(newRes, resBtn);

      newDec.addEventListener('click', () => {
        setVal(Math.max(minStep, getVal() - 1));
        update();
        savePrefs();
      });
      newInc.addEventListener('click', () => {
        setVal(Math.min(maxStep, getVal() + 1));
        update();
        savePrefs();
      });
      newRes.addEventListener('click', () => {
        setVal(0);
        update();
        savePrefs();
      });

      update();
    }

    makeSlider({
      decreaseId: 'font-decrease', increaseId: 'font-increase', resetId: 'font-reset',
      fillId: 'font-fill', thumbId: 'font-thumb',
      getVal: () => state.fontSize,
      setVal: (v) => {
        state.fontSize = v;
        html.style.fontSize = v === 0 ? '' : `calc(1rem + ${v * FONT_STEP_PX}px)`;
      },
      minStep: MIN_STEP, maxStep: MAX_STEP
    });

    makeSlider({
      decreaseId: 'word-decrease', increaseId: 'word-increase', resetId: 'word-reset',
      fillId: 'word-fill', thumbId: 'word-thumb',
      getVal: () => state.wordSpacing,
      setVal: (v) => {
        state.wordSpacing = v;
        document.body.style.wordSpacing = v === 0 ? '' : `${v * WORD_STEP}em`;
      },
      minStep: MIN_STEP, maxStep: MAX_STEP
    });

    makeSlider({
      decreaseId: 'letter-decrease', increaseId: 'letter-increase', resetId: 'letter-reset',
      fillId: 'letter-fill', thumbId: 'letter-thumb',
      getVal: () => state.letterSpacing,
      setVal: (v) => {
        state.letterSpacing = v;
        document.body.style.letterSpacing = v === 0 ? '' : `${v * LETTER_STEP}em`;
      },
      minStep: MIN_STEP, maxStep: MAX_STEP
    });

    // === Reset All ===
    if (resetAll) {
      const newResetAll = resetAll.cloneNode(true);
      resetAll.parentNode.replaceChild(newResetAll, resetAll);
      
      newResetAll.addEventListener('click', () => {
        state.filters.forEach(f => html.classList.remove('a11y-' + f));
        state.filters.clear();
        document.querySelectorAll('.a11y-filter-btn').forEach(b => b.setAttribute('aria-pressed', 'false'));

        state.fontSize = 0;
        html.style.fontSize = '';
        const ff = document.getElementById('font-fill');
        const ft = document.getElementById('font-thumb');
        if (ff) ff.style.width = '50%';
        if (ft) ft.style.left = 'calc(50% - 10px)';

        state.wordSpacing = 0;
        document.body.style.wordSpacing = '';
        const wf = document.getElementById('word-fill');
        const wt = document.getElementById('word-thumb');
        if (wf) wf.style.width = '50%';
        if (wt) wt.style.left = 'calc(50% - 10px)';

        state.letterSpacing = 0;
        document.body.style.letterSpacing = '';
        const lf = document.getElementById('letter-fill');
        const lt = document.getElementById('letter-thumb');
        if (lf) lf.style.width = '50%';
        if (lt) lt.style.left = 'calc(50% - 10px)';

        savePrefs();
      });
    }
  }

  // Initialize on full page load and after Astro View Transitions
  document.addEventListener('astro:page-load', initA11y);
  // Failsafe for normal load if astro:page-load doesn't fire immediately
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(initA11y, 100);
  } else {
    document.addEventListener('DOMContentLoaded', initA11y);
  }
</script>
