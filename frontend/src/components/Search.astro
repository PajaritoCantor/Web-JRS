---
// Search.astro - Buscador Omnipresente con Pagefind
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden opacity-0 transition-all duration-300 pointer-events-none">
  <!-- Overlay Dark with Blur -->
  <div class="absolute inset-0 bg-academic-dark/80 backdrop-blur-md" id="search-overlay"></div>
  
  <!-- Contenedor del Buscador -->
  <div class="relative w-full max-w-3xl mx-auto mt-20 md:mt-32 px-6">
    <div class="bg-zinc-900/90 border border-white/10 rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300" id="search-content">
      
      <!-- Input Area -->
      <div class="relative flex items-center p-6 border-b border-white/5">
        <i class="fa-solid fa-magnifying-glass text-academic-accent text-xl mr-4"></i>
        <input 
          type="text" 
          id="search-input" 
          placeholder="Busca por tema, libro, artículo..." 
          class="flex-1 bg-transparent border-none text-white text-xl focus:ring-0 placeholder:text-white/20 font-light"
          autocomplete="off"
        />
        <kbd class="hidden md:flex items-center gap-1 bg-white/5 px-3 py-1 rounded-lg text-[10px] text-white/40 uppercase font-black border border-white/5">
          Esc
        </kbd>
        <button id="close-search" class="ml-6 text-white/40 hover:text-white transition-colors">
          <i class="fa-solid fa-xmark text-xl"></i>
        </button>
      </div>

      <!-- Results Area -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2 space-y-2 custom-scrollbar">
        <!-- Los resultados se inyectarán aquí -->
        <div id="search-placeholder" class="py-20 text-center">
            <i class="fa-solid fa-feather-pointed text-white/5 text-6xl mb-6"></i>
            <p class="text-white/30 text-sm uppercase tracking-[0.2em] font-black">Escribe para explorar el archivo</p>
        </div>
      </div>

      <!-- Footer Info -->
      <div class="p-4 bg-black/40 border-t border-white/5 flex items-center justify-between text-[10px] uppercase font-black tracking-widest text-white/20">
        <div class="flex gap-4">
          <span><kbd class="bg-white/5 px-2 py-1 rounded">↵</kbd> Seleccionar</span>
          <span><kbd class="bg-white/5 px-2 py-1 rounded">↑↓</kbd> Navegar</span>
        </div>
        <div class="flex items-center gap-2">
            Poder de búsqueda por <span class="text-academic-accent/50 italic font-serif normal-case tracking-normal text-xs">Pagefind</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(251, 191, 36, 0.1);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(251, 191, 36, 0.2);
  }

  /* Animaciones */
  #search-modal.active {
    opacity: 1;
    pointer-events: auto;
  }
  #search-modal.active #search-content {
    transform: scale(1);
  }

  :global(.search-result-item) {
    display: block;
    padding: 1.5rem;
    border-radius: 1.5rem;
    background: transparent;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }
  :global(.search-result-item:hover) {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
    transform: translateX(4px);
  }
  :global(.search-result-title) {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
    display: block;
  }
  :global(.search-result-excerpt) {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.search-result-excerpt mark) {
    background: rgba(251, 191, 36, 0.2);
    color: #fbbf24;
    font-weight: 700;
  }
</style>

<script>
  let pagefind: any;

  async function initSearch() {
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsContainer = document.getElementById('search-results');
    const overlay = document.getElementById('search-overlay');
    const closeBtn = document.getElementById('close-search');
    const triggers = document.querySelectorAll('[aria-label="Buscar"]');

    // Cargar Pagefind dinámicamente — new Function() evita que Vite analice el import en dev mode
    try {
      pagefind = await new Function('return import("/pagefind/pagefind.js")')() as any;
      await pagefind.options({ highlightParam: "highlight" });
    } catch (e) {
      console.warn("Buscador: Índice no encontrado (normal en dev mode).");
    }

    const openModal = () => {
      modal?.classList.add('active');
      modal?.classList.remove('hidden');
      setTimeout(() => input?.focus(), 100);
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal?.classList.remove('active');
      setTimeout(() => modal?.classList.add('hidden'), 300);
      document.body.style.overflow = '';
    };

    triggers.forEach(trigger => trigger.addEventListener('click', openModal));
    overlay?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);

    // Keyboard Shortcuts
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openModal();
      }
      if (e.key === 'Escape') closeModal();
    });

    // Mapeo de URL a sección y su icono
    function getSectionInfo(url: string): { label: string; icon: string } {
      if (url.includes('/medios')) return { label: 'Medios', icon: 'fa-microphone-lines' };
      if (url.includes('/publicaciones/articulos')) return { label: 'Artículos', icon: 'fa-file-lines' };
      if (url.includes('/publicaciones/libros') || url.includes('/libros')) return { label: 'Libros', icon: 'fa-book' };
      if (url.includes('/biografia')) return { label: 'Biografía', icon: 'fa-user' };
      if (url.includes('/contacto')) return { label: 'Contacto', icon: 'fa-envelope' };
      if (url === '/' || url === '/index.html') return { label: 'Inicio', icon: 'fa-home' };
      return { label: 'Página', icon: 'fa-file' };
    }

    // Search Logic
    let debounceTimer: ReturnType<typeof setTimeout>;
    input?.addEventListener('input', async (e) => {
      clearTimeout(debounceTimer);
      const query = (e.target as HTMLInputElement).value;
      if (!query || query.length < 2) {
        if (resultsContainer) resultsContainer.innerHTML = `
          <div id="search-placeholder" class="py-20 text-center">
              <i class="fa-solid fa-feather-pointed text-white/5 text-6xl mb-6"></i>
              <p class="text-white/30 text-sm uppercase tracking-[0.2em] font-black">Escribe para explorar el archivo</p>
          </div>
        `;
        return;
      }

      if (!pagefind) {
        if (resultsContainer) resultsContainer.innerHTML = `
          <div class="py-20 text-center px-10">
              <i class="fa-solid fa-triangle-exclamation text-academic-accent/50 text-4xl mb-6"></i>
              <p class="text-white/50 text-sm uppercase tracking-widest font-black mb-2">Buscador en fase de indexación</p>
              <p class="text-white/20 text-xs">La búsqueda completa estará disponible tras el despliegue a producción.</p>
          </div>
        `;
        return;
      }

      debounceTimer = setTimeout(async () => {
        const search = await pagefind.search(query);
        const rawResults = await Promise.all(search.results.slice(0, 15).map((r: any) => r.data()));

        // Flatten: extract sub_results from each page result for element-level precision
        interface SubResult {
          title: string;
          url: string;
          excerpt: string;
          pageUrl: string;
        }
        const allSubResults: SubResult[] = [];

        for (const res of rawResults) {
          if (res.sub_results && res.sub_results.length > 0) {
            for (const sub of res.sub_results) {
              allSubResults.push({
                title: sub.title || res.meta?.title || 'Sin título',
                url: sub.url || res.url,
                excerpt: sub.excerpt || res.excerpt || '',
                pageUrl: res.url
              });
            }
          } else {
            allSubResults.push({
              title: res.meta?.title || 'Sin título',
              url: res.url,
              excerpt: res.excerpt || '',
              pageUrl: res.url
            });
          }
        }

        // Deduplicate by title — prefer detail pages over index
        const seen = new Map<string, SubResult>();
        for (const sr of allSubResults) {
          const key = sr.title.toLowerCase().trim();
          if (!seen.has(key)) {
            seen.set(key, sr);
          } else {
            // Prefer the URL that is NOT the homepage
            const existing = seen.get(key)!;
            if (existing.pageUrl === '/' || existing.pageUrl === '/index.html') {
              seen.set(key, sr);
            }
          }
        }

        const dedupedResults = Array.from(seen.values()).slice(0, 8);

        if (resultsContainer) {
          if (dedupedResults.length === 0) {
            resultsContainer.innerHTML = `
              <div class="py-20 text-center">
                  <i class="fa-solid fa-magnifying-glass-minus text-white/5 text-6xl mb-6"></i>
                  <p class="text-white/30 text-sm uppercase tracking-[0.2em] font-black">No hay resultados para "${query}"</p>
              </div>
            `;
          } else {
            resultsContainer.innerHTML = dedupedResults
              .map((sr) => {
                const section = getSectionInfo(sr.url);
                return `
                  <a href="${sr.url}" class="search-result-item" data-search-link>
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                      <span style="display:inline-flex;align-items:center;gap:6px;background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.15);padding:3px 10px;border-radius:999px;">
                        <i class="fa-solid ${section.icon}" style="font-size:9px;color:#fbbf24;"></i>
                        <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.15em;font-weight:900;color:rgba(251,191,36,0.7);">${section.label}</span>
                      </span>
                    </div>
                    <span class="search-result-title">${sr.title}</span>
                    <p class="search-result-excerpt">${sr.excerpt}</p>
                  </a>
                `;
              })
              .join('');

            // Click → store anchor in sessionStorage → navigate
            // The astro:page-load listener below will handle the scroll after navigation
            resultsContainer.querySelectorAll('[data-search-link]').forEach((link: Element) => {
              link.addEventListener('click', (ev) => {
                ev.preventDefault();
                const href = (link as HTMLAnchorElement).href;
                const hash = new URL(href, window.location.origin).hash;
                if (hash) {
                  sessionStorage.setItem('pf-target', hash.slice(1));
                }
                closeModal();
                setTimeout(() => {
                  window.location.href = href;
                }, 350);
              });
            });
          }
        }
      }, 200);
    });
  }

  // Ejecutar en cada carga de Astro
  document.addEventListener('astro:page-load', initSearch);

  // Al cargar la página, verificar si hay un target de búsqueda pendiente
  document.addEventListener('astro:page-load', () => {
    const targetId = sessionStorage.getItem('pf-target');
    if (!targetId) return;
    sessionStorage.removeItem('pf-target');

    setTimeout(() => {
      const target = document.getElementById(targetId);
      if (!target) return;

      // Si el target es un pf-anchor (height:0, invisible), desplazarse al hermano visible siguiente
      const isPfAnchor = target.classList.contains('pf-anchor');
      const scrollTarget = isPfAnchor
        ? (target.nextElementSibling as HTMLElement) || target
        : target;

      // Scroll preciso al elemento
      scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });

      // Highlight dorado temporal
      const el = scrollTarget;
      el.style.transition = 'outline 0.3s ease, outline-offset 0.3s ease, box-shadow 0.3s ease';
      el.style.outline = '2px solid rgba(251,191,36,0.6)';
      el.style.outlineOffset = '10px';
      el.style.borderRadius = '16px';
      el.style.boxShadow = '0 0 40px rgba(251,191,36,0.15)';

      setTimeout(() => {
        el.style.outline = 'none';
        el.style.boxShadow = 'none';
      }, 3000);
    }, 400);
  });
</script>
