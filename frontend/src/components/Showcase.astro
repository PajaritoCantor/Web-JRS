---
// Showcase Component
---
<section class="relative w-full h-[100vh] flex items-center justify-center overflow-hidden bg-academic-dark">
  
  <!-- Imagen de Fondo con Parallax Effect -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-academic-dark/60 backdrop-blur-[2px] z-10"></div>
    <img src="/assets/1000x1000.jpg" alt="Jerónimo Ríos Sierra" class="w-full h-full object-cover grayscale opacity-30 animate-fade-in" />
  </div>

  <!-- Contenido Central -->
  <div class="relative z-20 container mx-auto px-6 text-center animate-slide-up">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-[clamp(3rem,8vw,6rem)] font-black text-white leading-[0.9] tracking-tighter mb-12">
        Jerónimo <br/>
        <span class="text-academic-accent italic font-light">Ríos Sierra</span>
      </h2>
      
      <p class="font-sans text-academic-accent/90 text-xl md:text-3xl leading-relaxed mb-16 max-w-2xl mx-auto font-light tracking-tight">
        <strong class="text-academic-accent font-bold">Premio Extraordinario de Doctorado</strong>. <br/><span class="opacity-70">Análisis y prospectiva de conflictos armados.</span>
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-12">
        <a href="/biografia" class="group relative px-14 py-5 text-[10px] font-black tracking-[0.4em] uppercase text-academic-dark bg-white rounded-2xl hover:bg-academic-accent transition-all duration-700 hover:shadow-premium overflow-hidden">
          <span class="relative z-10">Biografía</span>
        </a>
        <a href="/publicaciones/articulos" class="text-[10px] font-black text-white/50 hover:text-academic-accent transition-colors uppercase tracking-[0.4em] relative group pb-2">
          Publicaciones
          <span class="absolute bottom-0 left-0 w-full h-[1px] bg-academic-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></span>
        </a>
      </div>
    </div>
  </div>

  <!-- Indicador de Scroll -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-6 opacity-30 animate-bounce">
    <span class="text-[9px] uppercase tracking-[0.8em] font-black text-slate-500">EXPLORAR</span>
    <div class="w-[1px] h-16 bg-gradient-to-b from-slate-500 to-transparent"></div>
  </div>

</section>
