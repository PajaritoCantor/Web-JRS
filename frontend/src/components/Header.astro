---
// Header Component
---
<header class="fixed top-0 left-0 w-full bg-white/95 backdrop-blur-xl h-[80px] md:h-[100px] border-b border-zinc-200/50 z-50 flex items-center justify-between px-6 md:px-12 transition-all duration-300">
  
  <!-- Logo y Nombre -->
  <div class="flex-shrink-0 z-20">
    <a href="/" class="flex items-center gap-4 group">
      <div class="w-10 h-10 md:w-12 md:h-12 bg-black rounded-xl flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform">
        <span class="text-academic-accent font-serif font-black text-xl md:text-2xl">J</span>
      </div>
      <div class="hidden lg:block text-black">
        <h1 class="font-serif text-xl font-black leading-none tracking-tight">Jerónimo Ríos</h1>
        <span class="text-xs uppercase tracking-[0.3em] font-black opacity-40">Sierra</span>
      </div>
    </a>
  </div>
  
  <!-- Navegación Central Desktop -->
  <nav class="hidden md:flex flex-1 items-center justify-center z-10">
    <ul class="flex items-center space-x-12 text-xs lg:text-sm tracking-[0.3em] uppercase font-black text-black">
      <li>
        <a href="/biografia" class="nav-link-underline hover:text-academic-dark transition-colors">
          Biografía
        </a>
      </li>
      <li class="relative group">
        <button
          id="publicaciones-toggle"
          type="button"
          class="nav-link-underline hover:text-academic-dark transition-colors inline-flex items-center gap-2 text-xs lg:text-sm tracking-[0.3em] uppercase font-black leading-none"
          aria-expanded="false"
          aria-controls="publicaciones-menu"
        >
          Publicaciones
          <i class="fa-solid fa-chevron-down text-xs transition-transform duration-200 group-hover:rotate-180" aria-hidden="true"></i>
        </button>
        <div
          id="publicaciones-menu"
          class="absolute left-1/2 top-full z-40 w-60 -translate-x-1/2 pt-2 opacity-0 pointer-events-none translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0"
          role="menu"
        >
          <div class="rounded-xl border border-zinc-200/60 bg-gradient-to-br from-white/95 via-gray-50/95 to-amber-50/95 p-2 shadow-xl shadow-zinc-900/10 backdrop-blur-md">
            <a href="/publicaciones/articulos" class="block rounded-lg px-4 py-3 text-xs tracking-[0.18em] uppercase font-black text-academic-dark/70 hover:bg-white/70 hover:text-academic-dark transition-colors" role="menuitem">
              Artículos
            </a>
            <a href="/publicaciones/libros" class="block rounded-lg px-4 py-3 text-xs tracking-[0.18em] uppercase font-black text-academic-dark/70 hover:bg-white/70 hover:text-academic-dark transition-colors" role="menuitem">
              Libros
            </a>
          </div>
        </div>
      </li>
      <li>
        <a href="/medios" class="nav-link-underline hover:text-academic-dark transition-colors">
          Medios
        </a>
      </li>
      <li>
        <a href="/contacto" class="nav-link-underline hover:text-academic-dark transition-colors">
          Contacto
        </a>
      </li>
    </ul>
  </nav>

  <!-- Utilidades: Buscador y Redes (Desktop) -->
  <div class="hidden md:flex items-center space-x-6 text-black z-20">
    
    <!-- Redes Sociales -->
    <div class="flex items-center space-x-5 border-r border-black/10 pr-6">
      <a href="#" aria-label="X" class="text-black hover:scale-125 transition-all duration-300 flex items-center justify-center">
        <svg class="w-[16px] h-[16px] opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4l16 16M4 20L20 4"/>
        </svg>
      </a>
      <a href="#" aria-label="LinkedIn" class="text-black hover:scale-125 transition-all duration-300 flex items-center justify-center">
        <svg class="w-[16px] h-[16px] opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
      <a href="mailto:info@jeronimorios.com" aria-label="Gmail" class="text-black hover:scale-125 transition-all duration-300 flex items-center justify-center">
        <svg class="w-[16px] h-[16px] opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
    </div>

    <!-- Buscador -->
    <button aria-label="Buscar" class="text-black hover:opacity-70 transition-colors flex items-center group">
      <i class="fa-solid fa-magnifying-glass text-[17px]"></i>
      <span class="ml-2 text-sm uppercase tracking-widest font-black hidden xl:inline-block">Buscar</span>
    </button>
  </div>

  <!-- Botones UI Móvil -->
  <div class="md:hidden flex items-center gap-5 z-20">
    <button aria-label="Buscar" class="text-gray-600 hover:text-black transition-colors">
      <i class="fa-solid fa-magnifying-glass text-lg"></i>
    </button>
    <div class="relative">
      <button id="publicaciones-mobile-toggle" class="text-sm uppercase tracking-widest font-black text-academic-dark/70 hover:text-academic-dark transition-colors" aria-expanded="false" aria-controls="publicaciones-mobile-menu">
        Publicaciones
      </button>
      <div id="publicaciones-mobile-menu" class="hidden absolute right-0 top-full mt-3 w-52 rounded-xl border border-zinc-200/60 bg-gradient-to-br from-white/95 via-gray-50/95 to-amber-50/95 p-2 shadow-premium backdrop-blur-md transition-all duration-300">
        <a href="/publicaciones/articulos" class:list={[
          "block rounded-lg px-4 py-3 text-xs tracking-[0.18em] uppercase font-black transition-colors",
          "text-academic-dark/70 hover:bg-white/70 hover:text-academic-dark"
        ]}>
          Artículos
        </a>
        <a href="/publicaciones/libros" class:list={[
          "block rounded-lg px-4 py-3 text-xs tracking-[0.18em] uppercase font-black transition-colors",
          "text-academic-dark/70 hover:bg-white/70 hover:text-academic-dark"
        ]}>
          Libros
        </a>
      </div>
    </div>
    <button class="text-2xl text-gray-800 focus:outline-none" aria-label="Abrir Menú">
      <i class="fa-solid fa-bars-staggered"></i>
    </button>
  </div>
</header>

<script>
  const desktopToggle = document.getElementById('publicaciones-toggle');
  const desktopMenu = document.getElementById('publicaciones-menu');
  const mobileToggle = document.getElementById('publicaciones-mobile-toggle');
  const mobileMenu = document.getElementById('publicaciones-mobile-menu');

  const closeDesktopMenu = () => {
    if (!desktopToggle || !desktopMenu) return;
    desktopToggle.setAttribute('aria-expanded', 'false');
    desktopMenu.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
  };

  if (desktopToggle && desktopMenu) {
    desktopToggle.addEventListener('click', (event) => {
      event.preventDefault();
      const expanded = desktopToggle.getAttribute('aria-expanded') === 'true';
      desktopToggle.setAttribute('aria-expanded', String(!expanded));
      desktopMenu.classList.toggle('opacity-0', expanded);
      desktopMenu.classList.toggle('pointer-events-none', expanded);
      desktopMenu.classList.toggle('translate-y-2', expanded);
    });
  }

  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', () => {
      const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.classList.toggle('hidden', expanded);
      // Animación sutil de entrada
      if (!expanded) {
        mobileMenu.animate([
          { opacity: 0, transform: 'translateY(10px)' },
          { opacity: 1, transform: 'translateY(0)' }
        ], { duration: 300, easing: 'ease-out' });
      }
    });
  }

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (desktopToggle && desktopMenu && !desktopToggle.contains(target) && !desktopMenu.contains(target)) {
      closeDesktopMenu();
    }

    if (mobileToggle && mobileMenu && !mobileToggle.contains(target) && !mobileMenu.contains(target)) {
      mobileToggle.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.add('hidden');
    }
  });
</script>
