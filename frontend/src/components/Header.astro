---
// Header Component
---
<header class="fixed top-0 left-0 w-full bg-white/80 backdrop-blur-xl h-[80px] md:h-[100px] border-b border-zinc-200/50 z-50 flex items-center justify-between px-6 md:px-12 transition-all duration-300">
  
  <!-- Logo y Nombre -->
  <div class="flex-shrink-0 z-20">
    <a href="/" class="flex items-center gap-4 group">
      <img src="/assets/original.jpeg" alt="Jerónimo Ríos" class="w-[45px] md:w-[50px] h-[45px] md:h-[50px] rounded-full object-cover shadow-sm group-hover:shadow-md transition-all duration-500 group-hover:scale-105">
      <div class="hidden lg:block text-academic-dark">
        <h1 class="font-serif text-xl font-bold leading-none tracking-tight group-hover:text-academic-accent transition-colors duration-300">Jerónimo Ríos</h1>
      </div>
    </a>
  </div>
  
  <!-- Navegación Central Desktop -->
  <nav class="hidden md:flex flex-1 items-center justify-center z-10">
    <ul class="flex items-center space-x-12 text-[10px] lg:text-[11px] tracking-[0.3em] uppercase font-black text-academic-dark/60">
      <li>
        <a href="/biografia" class="nav-link-underline hover:text-academic-dark transition-colors">
          Biografía
        </a>
      </li>
      <li>
        <a href="#" class="nav-link-underline hover:text-academic-dark transition-colors">
          Publicaciones
        </a>
      </li>
      <li>
        <a href="#" class="nav-link-underline hover:text-academic-dark transition-colors">
          Pensamiento
        </a>
      </li>
      <li>
        <a href="#" class="nav-link-underline hover:text-academic-dark transition-colors">
          Contacto
        </a>
      </li>
    </ul>
  </nav>

  <!-- Utilidades: Buscador y Redes (Desktop) -->
  <div class="hidden md:flex items-center space-x-6 text-gray-500 z-20">
    
    <!-- Redes Sociales -->
    <div class="flex items-center space-x-5 border-r border-zinc-200 pr-6">
      <a href="#" aria-label="X" class="text-academic-dark/40 hover:text-black transition-all hover:scale-125 duration-300">
        <i class="fa-brands fa-x-twitter text-[16px]"></i>
      </a>
      <a href="#" aria-label="LinkedIn" class="text-academic-dark/40 hover:text-[#0a66c2] transition-all hover:scale-125 duration-300">
        <i class="fa-brands fa-linkedin-in text-[16px]"></i>
      </a>
      <a href="#" aria-label="Instagram" class="text-academic-dark/40 hover:text-[#E1306C] transition-all hover:scale-125 duration-300">
        <i class="fa-brands fa-instagram text-[16px]"></i>
      </a>
      <a href="mailto:info@jeronimorios.com" aria-label="Gmail" class="text-academic-dark/40 hover:text-academic-accent transition-all hover:scale-125 duration-300">
        <i class="fa-solid fa-envelope text-[16px]"></i>
      </a>
    </div>

    <!-- Buscador -->
    <button aria-label="Buscar" class="hover:text-black transition-colors flex items-center group">
      <i class="fa-solid fa-magnifying-glass text-[17px]"></i>
      <span class="ml-2 text-[11px] uppercase tracking-widest font-semibold group-hover:text-black transition-colors hidden xl:inline-block">Buscar</span>
    </button>
  </div>

  <!-- Botones UI Móvil -->
  <div class="md:hidden flex items-center gap-5 z-20">
    <button aria-label="Buscar" class="text-gray-600 hover:text-black transition-colors">
      <i class="fa-solid fa-magnifying-glass text-lg"></i>
    </button>
    <button class="text-2xl text-gray-800 focus:outline-none" aria-label="Abrir Menú">
      <i class="fa-solid fa-bars-staggered"></i>
    </button>
  </div>
</header>
