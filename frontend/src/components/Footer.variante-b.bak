<footer class="w-full bg-academic-dark text-white border-t border-white/5 relative overflow-hidden">
  <!-- Fondo decorativo sutil -->
  <div class="absolute top-0 right-0 w-[40%] h-full bg-academic-accent/5 blur-[100px] rounded-full translate-x-1/2 -z-10"></div>

  <div class="max-w-[1440px] mx-auto px-8 md:px-16">

    <!-- Fila principal: Logo · Nav · Redes -->
    <div class="py-12 flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Logo + Nombre -->
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <div class="w-9 h-9 rounded-lg bg-academic-accent flex items-center justify-center transition-transform group-hover:rotate-12">
          <span class="text-academic-dark font-serif font-bold text-lg">J</span>
        </div>
        <span class="font-serif text-xl font-black text-white tracking-tight">Jerónimo Ríos <span class="text-slate-400 italic">Sierra</span></span>
      </a>

      <!-- Navegación central -->
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        <a href="/biografia" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white/40 hover:text-academic-accent transition-colors">Biografía</a>
        <a href="/publicaciones/articulos" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white/40 hover:text-academic-accent transition-colors">Artículos</a>
        <a href="/publicaciones/libros" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white/40 hover:text-academic-accent transition-colors">Libros</a>
        <a href="/medios" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white/40 hover:text-academic-accent transition-colors">Medios</a>
        <a href="/contacto" class="text-[11px] uppercase tracking-[0.2em] font-bold text-white/40 hover:text-academic-accent transition-colors">Contacto</a>
      </nav>

      <!-- Redes sociales -->
      <div class="flex items-center gap-5 shrink-0">
        <a href="#" aria-label="X" class="text-zinc-500 hover:text-white transition-colors group">
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4l16 16M4 20L20 4"/>
          </svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="text-zinc-500 hover:text-white transition-colors group">
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="#" aria-label="Instagram" class="text-zinc-500 hover:text-white transition-colors group">
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="mailto:info@jeronimorios.com" aria-label="Email" class="text-zinc-500 hover:text-white transition-colors group">
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </a>
      </div>
    </div>

    <!-- Barra legal -->
    <div class="py-6 border-t border-white/[0.06] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-zinc-600 text-[10px] uppercase tracking-[0.2em] font-medium">
        © {new Date().getFullYear()} Jerónimo Ríos Sierra. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-5 text-zinc-600 text-[10px] uppercase tracking-[0.15em] font-medium">
        <a href="/privacidad" class="hover:text-zinc-300 transition-colors">Privacidad</a>
        <span class="opacity-30">|</span>
        <a href="/aviso-legal" class="hover:text-zinc-300 transition-colors">Aviso Legal</a>
        <span class="opacity-30">|</span>
        <a href="/cookies" class="hover:text-zinc-300 transition-colors">Cookies</a>
        <span class="opacity-30">|</span>
        <a href="/accesibilidad" class="hover:text-zinc-300 transition-colors">Accesibilidad</a>
      </div>
    </div>

  </div>
</footer>
