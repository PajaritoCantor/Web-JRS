---
interface Props {
  titulo: string;
  revista: string;
  anio: number;
  urlExterna: string;
  descripcionCorta?: string;
  dark?: boolean;
}

const {
  titulo,
  revista,
  anio,
  urlExterna,
  descripcionCorta = '',
  dark = false
} = Astro.props as Props;
---

<article 
  data-category={revista.includes('Q1') || revista.includes('Q2') ? 'q1q2' : 'general'}
  data-journal={revista.toLowerCase()}
  class:list={[
  "group relative border-t py-7 md:py-8 transition-all duration-500 article-card",
  dark ? "border-white/10" : "border-zinc-300/60"
]}>
  <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-8 items-start">
    <div>
      <p class:list={[
        "font-sans text-xs tracking-[0.2em] uppercase mb-3",
        dark ? "text-slate-400 font-bold" : "text-zinc-500"
      ]}>
        {revista} · {anio}
      </p>
      <h3 class:list={[
        "font-serif text-2xl md:text-3xl leading-tight transition-colors duration-300",
        dark ? "text-white group-hover:text-academic-accent" : "text-slate-900 group-hover:text-blue-900"
      ]}>
        {titulo}
      </h3>
      {descripcionCorta && (
        <p class:list={[
          "mt-4 leading-relaxed font-sans text-sm md:text-base max-w-3xl",
          dark ? "text-slate-300 font-light" : "text-slate-700/90"
        ]}>
          {descripcionCorta}
        </p>
      )}
    </div>

    <div class="pt-1">
      <a
        href={urlExterna}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          "inline-flex items-center gap-3 rounded-full border px-5 py-2.5 font-sans text-xs tracking-[0.18em] uppercase font-black transition-colors duration-300",
          dark ? "border-white/10 bg-white/5 text-white/70 hover:border-academic-accent/50 hover:text-academic-accent hover:bg-white/10" : "border-slate-300/70 bg-white/80 text-slate-700 hover:border-blue-900/30 hover:text-blue-900 hover:bg-white"
        ]}
      >
        Leer en fuente original
        <i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</article>
