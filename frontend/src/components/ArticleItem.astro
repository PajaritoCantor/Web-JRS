---
interface Props {
  titulo: string;
  revista: string;
  anio: number;
  urlExterna: string;
  descripcionCorta?: string;
}

const {
  titulo,
  revista,
  anio,
  urlExterna,
  descripcionCorta = ''
} = Astro.props as Props;
---

<article class="group relative border-t border-zinc-300/60 py-7 md:py-8">
  <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-8 items-start">
    <div>
      <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-zinc-500 mb-3">
        {revista} · {anio}
      </p>
      <h3 class="font-serif text-2xl md:text-3xl leading-tight text-slate-900 group-hover:text-blue-900 transition-colors duration-300">
        {titulo}
      </h3>
      {descripcionCorta && (
        <p class="mt-4 text-slate-700/90 leading-relaxed font-sans text-sm md:text-base max-w-3xl">
          {descripcionCorta}
        </p>
      )}
    </div>

    <div class="pt-1">
      <a
        href={urlExterna}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-full border border-slate-300/70 bg-white/80 px-5 py-2.5 font-sans text-[10px] tracking-[0.18em] uppercase font-black text-slate-700 hover:border-blue-900/30 hover:text-blue-900 hover:bg-white transition-colors duration-300"
      >
        Leer en fuente original
        <i class="fa-solid fa-arrow-up-right-from-square text-[10px]" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</article>
