---
// EditorialGrid.astro
// Enfoque: UI Editorial Premium con Sincronización de Media
---

<section data-pagefind-ignore class="max-w-[1440px] mx-auto px-6 pt-24 pb-12">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[300px] md:auto-rows-[350px]">
    
    <div class="md:col-span-2 md:row-span-1 bg-white/5 backdrop-blur-sm rounded-3xl p-12 flex flex-col justify-end border border-white/5 hover:border-academic-accent/20 hover:shadow-2xl hover:shadow-academic-accent/5 transition-all duration-700 group">
        <h2 class="text-xs font-black tracking-[0.3em] uppercase text-academic-accent mb-6 animate-pulse">Actualidad</h2>
        <h3 class="font-serif text-5xl md:text-6xl font-black text-white leading-tight tracking-tighter">
            Análisis & <br/><span class="text-academic-accent italic font-light">Perspectiva Crítica</span>
        </h3>
    </div>

    <div class="md:col-span-2 md:row-span-2 relative rounded-3xl overflow-hidden group shadow-2xl border border-white/20">
        <img src="/assets/medios/paz_total_petro.jpg" alt="El fracaso de la paz total de Petro" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-academic-dark/90 via-academic-dark/20 to-transparent p-12 flex flex-col justify-end backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all duration-700">
            <div class="flex items-center justify-between mb-4">
                <span class="text-[10px] uppercase tracking-[0.2em] font-black text-academic-accent">Destacado en Medios</span>
                <a href="/medios" class="text-[9px] uppercase tracking-[0.3em] font-bold text-white/40 hover:text-white transition-all border-b border-white/5 hover:border-white/20 pb-0.5">Explorar Archivo →</a>
            </div>
            <h4 class="text-white text-3xl md:text-4xl font-serif font-black leading-[1.1] mb-8 tracking-tight">El fracaso de la paz total de Petro</h4>
            <a href="https://www.rtve.es/play/audios/cinco-continentes/cinco-continentes-fracaso-paz-total-petro/16865608/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-4 text-white text-xs font-black uppercase tracking-[0.3em] border-b border-white/20 pb-2 w-max hover:border-academic-accent hover:text-academic-accent transition-all group/link">
                Escuchar Intervención
                <i class="fa-solid fa-headphones transition-transform group-hover/link:translate-x-2"></i>
            </a>
        </div>
    </div>

    <div class="md:col-span-2 md:row-span-1 group/event rounded-3xl overflow-hidden shadow-2xl bg-white flex flex-col border border-white/5 transition-all duration-700 cursor-pointer">
        <!-- Parte Superior: Imagen y Ubicación -->
        <div class="relative h-[200px] w-full overflow-hidden shrink-0">
            <img src="/assets/original.jpeg" alt="Seminario" class="w-full h-full object-cover grayscale opacity-90 group-hover/event:scale-110 group-hover/event:grayscale-0 group-hover/event:opacity-100 transition-all duration-1000" />
            <!-- Gradiente Inferior -->
            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-academic-dark to-transparent flex items-end p-5">
                <p class="text-white font-black tracking-widest uppercase text-xs flex items-center gap-2">
                    <span class="text-xl">🇪🇸</span> Madrid, España
                </p>
            </div>
            <!-- Etiqueta superior -->
            <div class="absolute top-5 left-5 bg-academic-accent text-academic-dark text-[9px] font-black uppercase tracking-[0.3em] px-3 py-1.5 rounded-full shadow-lg">
                Agenda Próxima
            </div>
        </div>

        <!-- Parte Inferior: Fecha + Detalles (Asimétrica y Estética) -->
        <div class="flex flex-1 items-stretch bg-white">
            <!-- Columna Fecha (Más estrecha, alineada arriba) -->
            <div class="w-[120px] md:w-[140px] border-r border-zinc-100 flex flex-col items-center justify-start pt-8 pb-6 px-4 shrink-0 relative overflow-hidden">
                <div class="absolute inset-0 bg-academic-accent/5 opacity-0 group-hover/event:opacity-100 transition-opacity duration-500"></div>
                <span class="text-[64px] font-serif font-black text-academic-dark leading-none tracking-tighter mb-1 relative z-10 transition-transform group-hover/event:scale-105">15</span>
                <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-400 relative z-10">Mayo</span>
                <span class="text-[9px] font-bold tracking-widest text-zinc-300 mt-1 relative z-10">2026</span>
            </div>
            
            <!-- Columna Detalles (Más amplia, con más espacio negativo) -->
            <div class="flex-1 p-8 md:pl-10 flex flex-col justify-between">
                <div>
                    <h3 class="font-serif font-black text-xl md:text-2xl text-academic-dark leading-snug tracking-tight mb-4 group-hover/event:text-academic-accent transition-colors">Seminario sobre Terrorismo de Estado</h3>
                    <p class="text-xs md:text-[13px] text-zinc-500 leading-relaxed font-medium line-clamp-3">Ponencia principal sobre el impacto y las dinámicas prolongadas de violencias asimétricas en Europa y América Latina.</p>
                </div>
                
                <a href="#" class="mt-8 font-black uppercase tracking-[0.25em] text-[10px] text-academic-dark flex items-center gap-3 w-max group/link hover:text-academic-accent transition-colors">
                    Portal del Evento
                    <span class="block w-6 h-[1.5px] bg-academic-accent group-hover/link:w-16 transition-all duration-500"></span>
                </a>
            </div>
        </div>
    </div>



    <div class="md:col-span-4 md:row-span-1 bg-white/[0.03] backdrop-blur-md rounded-3xl p-6 lg:px-12 lg:py-10 flex flex-col lg:flex-row items-start lg:items-center gap-6 lg:gap-8 border border-white/5 overflow-hidden group/news relative">
        <!-- Decorativo fondo -->
        <div class="absolute right-0 lg:-right-4 top-4 lg:top-1/2 lg:-translate-y-1/2 text-[60px] lg:text-[120px] font-black text-white/[0.02] lg:rotate-90 pointer-events-none select-none uppercase tracking-tighter hidden lg:block">
            News
        </div>

        <!-- Cabecera vertical izquierda -->
        <div class="shrink-0 flex flex-row lg:flex-col items-center lg:items-start justify-between w-full lg:w-auto h-auto lg:h-full border-b lg:border-b-0 lg:border-r border-white/5 pb-4 lg:pb-0 lg:pr-8 min-w-auto lg:min-w-[120px]">
            <span class="text-[9px] font-black tracking-[0.3em] uppercase text-academic-accent border-l-2 border-academic-accent pl-2 block">Últimas<br class="hidden lg:block"/>Novedades</span>
            <div class="lg:hidden text-[10px] text-white/30 tracking-widest uppercase flex items-center gap-2">
                Deslizar <i class="fa-solid fa-arrow-right-long animate-pulse"></i>
            </div>
        </div>

        <!-- 3 ítems en scroll horizontal (móvil) o columnas (desktop) -->
        <div class="flex-1 w-full flex lg:grid lg:grid-cols-3 gap-4 lg:gap-0 divide-x-0 lg:divide-x divide-white/5 relative z-10 overflow-x-auto lg:overflow-visible snap-x snap-mandatory pb-4 lg:pb-0 scrollbar-hide">

            <!-- Item 1: Audio -->
            <div class="news-item group cursor-pointer p-6 lg:p-0 lg:px-8 flex flex-col justify-between h-[200px] lg:h-full min-w-[260px] lg:min-w-0 bg-white/5 lg:bg-transparent rounded-2xl lg:rounded-none border border-white/5 lg:border-0 snap-center shrink-0"
                data-type="audio"
                data-thumbnail="/assets/medios/paz_total_petro.jpg"
                data-url="https://www.rtve.es/play/audios/cinco-continentes/cinco-continentes-fracaso-paz-total-petro/16865608/"
                role="link"
                aria-label="Escuchar: El fracaso de la paz total de Petro">
                <span class="text-[8px] uppercase font-black text-academic-accent bg-academic-accent/10 lg:bg-transparent px-3 lg:px-0 py-1 lg:py-0 rounded-full lg:rounded-none border border-academic-accent/20 lg:border-0 self-start mb-4">Audio</span>
                <p class="text-sm font-black tracking-wide text-white/80 uppercase group-hover:text-white transition-colors leading-snug flex-1">El fracaso de la paz total de Petro</p>
                <div class="flex items-center justify-between mt-6 pt-4 border-t border-white/5">
                    <span class="text-[9px] text-zinc-500 uppercase tracking-widest">RTVE · 2025</span>
                    <i class="fa-solid fa-headphones text-xs text-white/20 group-hover:text-academic-accent group-hover:scale-110 transition-all"></i>
                </div>
            </div>

            <!-- Item 2: Libro -->
            <div class="news-item group cursor-pointer p-6 lg:p-0 lg:px-8 flex flex-col justify-between h-[200px] lg:h-full min-w-[260px] lg:min-w-0 bg-white/5 lg:bg-transparent rounded-2xl lg:rounded-none border border-white/5 lg:border-0 snap-center shrink-0"
                data-type="book"
                data-thumbnail="/assets/covers/tupamaros.jpg"
                data-url="/publicaciones/libros"
                role="link"
                aria-label="Ver libro: Tupamaros en Uruguay">
                <span class="text-[8px] uppercase font-black text-white/50 bg-white/5 lg:bg-transparent px-3 lg:px-0 py-1 lg:py-0 rounded-full lg:rounded-none border border-white/10 lg:border-0 self-start mb-4">Libro</span>
                <p class="text-sm font-black tracking-wide text-white/80 uppercase group-hover:text-white transition-colors leading-snug flex-1">Tupamaros en Uruguay</p>
                <div class="flex items-center justify-between mt-6 pt-4 border-t border-white/5">
                    <span class="text-[9px] text-zinc-500 uppercase tracking-widest">Ed. Catarata · 2024</span>
                    <i class="fa-solid fa-book text-xs text-white/20 group-hover:text-academic-accent transition-all"></i>
                </div>
            </div>

            <!-- Item 3: Artículo -->
            <div class="news-item group cursor-pointer p-6 lg:p-0 lg:px-8 flex flex-col justify-between h-[200px] lg:h-full min-w-[260px] lg:min-w-0 bg-white/5 lg:bg-transparent rounded-2xl lg:rounded-none border border-white/5 lg:border-0 snap-center shrink-0"
                data-type="article"
                data-thumbnail="/assets/covers/critical_studies.jpg"
                data-url="https://www.tandfonline.com/doi/full/10.1080/17539153.2025.2598096"
                role="link"
                aria-label="Leer artículo: Víctimas del terrorismo de estado en España">
                <span class="text-[8px] uppercase font-black text-white/50 bg-white/5 lg:bg-transparent px-3 lg:px-0 py-1 lg:py-0 rounded-full lg:rounded-none border border-white/10 lg:border-0 self-start mb-4">Artículo</span>
                <p class="text-sm font-black tracking-wide text-white/80 uppercase group-hover:text-white transition-colors leading-snug flex-1">Víctimas del terrorismo de estado en España</p>
                <div class="flex items-center justify-between mt-6 pt-4 border-t border-white/5">
                    <span class="text-[9px] text-zinc-500 uppercase tracking-widest">Tandfonline · 2025</span>
                    <i class="fa-solid fa-arrow-right text-xs text-white/20 group-hover:text-academic-accent group-hover:translate-x-1 transition-all"></i>
                </div>
            </div>
        </div>

        <!-- Mini-player -->
        <a id="media-trigger"
             href="#"
             class="hidden lg:flex flex-col items-center justify-center w-44 h-44 shrink-0 bg-gradient-to-br from-academic-dark to-slate-900 rounded-2xl shadow-2xl p-4 rotate-6 group-hover/news:rotate-3 transition-all duration-700 border border-white/5 relative overflow-hidden group/play cursor-pointer ml-4"
             aria-label="Ver contenido destacado">

            <div id="thumbnail-bg" class="absolute inset-0 bg-cover bg-center opacity-0 transition-opacity duration-500 z-0"></div>

            <video id="preview-player" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 z-[1] pointer-events-none" muted loop playsinline>
                <source src="" type="video/mp4">
            </video>

            <div id="play-button-container" class="w-14 h-14 rounded-full bg-academic-dark flex items-center justify-center shadow-lg group-hover/play:scale-110 transition-all duration-500 relative z-10">
                <div id="pulse-ring" class="absolute inset-0 rounded-full bg-academic-accent animate-ping-slow opacity-0"></div>
                <i id="main-play-icon" class="fa-solid fa-external-link-alt text-base text-white transition-colors"></i>
            </div>

            <span id="media-label" class="mt-3 text-[8px] font-black uppercase tracking-[0.2em] text-white/50 opacity-0 group-hover/news:opacity-100 transition-all duration-1000 relative z-10">Explorar</span>
        </a>
    </div>


  </div>
</section>

<script>
  function setupEditorialGrid() {
      const newsItems = document.querySelectorAll('.news-item');
      const player = document.getElementById('preview-player') as HTMLVideoElement;
      const thumbnailBg = document.getElementById('thumbnail-bg');
      const pulseRing = document.getElementById('pulse-ring');
      const playIcon = document.getElementById('main-play-icon');
      const playButtonContainer = document.getElementById('play-button-container');
      const mediaLabel = document.getElementById('media-label');
      const mediaTrigger = document.getElementById('media-trigger') as HTMLAnchorElement;

      let currentUrl = '#';

      newsItems.forEach(item => {
        // Al hacer click en el item de la lista
        item.addEventListener('click', (e) => {
          const url = item.getAttribute('data-url');
          if (url) {
            window.open(url, url.startsWith('/') ? '_self' : '_blank');
          }
        });

        item.addEventListener('mouseenter', () => {
          const type = item.getAttribute('data-type');
          const videoSrc = item.getAttribute('data-src');
          const thumbSrc = item.getAttribute('data-thumbnail');
          const url = item.getAttribute('data-url');
          
          if (url) currentUrl = url;
          if (mediaTrigger) {
              mediaTrigger.href = currentUrl;
              mediaTrigger.target = currentUrl.startsWith('/') ? '_self' : '_blank';
          }

          // 1. Reset multimedia
          if (player) {
              player.style.opacity = '0';
              player.pause();
          }
          
          // Activar Thumbnail para todos los ítems (Proyección mejorada)
          if (thumbnailBg) {
              thumbnailBg.style.opacity = '0';
              if (thumbSrc) {
                  thumbnailBg.style.backgroundImage = `url('${thumbSrc}')`;
                  thumbnailBg.style.opacity = '0.6'; // Aumentada opacidad para mejor proyección
              }
          }

          pulseRing?.classList.remove('opacity-0');
          pulseRing?.classList.add('opacity-40');
          if (playButtonContainer) {
              playButtonContainer.classList.add('bg-academic-accent');
              playButtonContainer.classList.remove('bg-academic-dark');
          }
          if (playIcon) {
              playIcon.classList.remove('text-white');
              playIcon.classList.add('text-academic-dark');
          }

          if (type === 'video' && videoSrc && player) {
              if (player.src !== videoSrc) {
                  player.src = videoSrc;
                  player.load();
              }
              player.style.opacity = '1';
              player.play().catch(() => {});
              
              if(playIcon) playIcon.className = "fa-solid fa-play text-2xl text-academic-dark ml-1 transition-colors";
              if(mediaLabel) mediaLabel.textContent = "Ver Video";
          } else if (type === 'audio') {
              if(playIcon) playIcon.className = "fa-solid fa-headphones text-xl text-academic-dark transition-colors";
              if(mediaLabel) mediaLabel.textContent = "Escuchar";
          } else if (type === 'book') {
              if(playIcon) playIcon.className = "fa-solid fa-book-open text-xl text-academic-dark transition-colors";
              if(mediaLabel) mediaLabel.textContent = "Ver Libro";
          } else {
              if(playIcon) playIcon.className = "fa-solid fa-file-lines text-xl text-academic-dark transition-colors";
              if(mediaLabel) mediaLabel.textContent = "Leer Artículo";
          }
        });
      });

      const gridSection = document.querySelector('section');
      if (gridSection) {
        gridSection.addEventListener('mouseleave', () => {
            if (player) {
                player.style.opacity = '0';
                player.pause();
            }
            if (thumbnailBg) thumbnailBg.style.opacity = '0';
            pulseRing?.classList.add('opacity-0');
            pulseRing?.classList.remove('opacity-40');
            if (playButtonContainer) {
                playButtonContainer.classList.remove('bg-academic-accent');
                playButtonContainer.classList.add('bg-academic-dark');
            }
            if (playIcon) {
                playIcon.classList.add('text-white');
                playIcon.className = "fa-solid fa-external-link-alt text-lg text-white transition-colors";
            }
            if(mediaLabel) mediaLabel.textContent = "Explorar";
            if(mediaTrigger) {
                mediaTrigger.href = "#";
                mediaTrigger.target = "_self";
            }
        });
      }
  }

  // Ejecutar al cargar la página y en cada transición de Astro
  document.addEventListener('astro:page-load', setupEditorialGrid);
</script>

<style>
  .shadow-premium {
    box-shadow: 0 20px 50px -12px rgba(180, 140, 60, 0.15);
  }
  .animate-ping-slow {
    animation: ping 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  /* Ocultar barra de desplazamiento en contenedores de tipo carrusel */
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  .scrollbar-hide {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
  }
</style>