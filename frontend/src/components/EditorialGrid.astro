---
// EditorialGrid.astro
// Enfoque: UI Editorial Premium con Sincronización de Media
---

<section class="max-w-[1440px] mx-auto px-6 pt-24 pb-12">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[300px] md:auto-rows-[350px]">
    
    <div class="md:col-span-2 md:row-span-1 bg-white/5 backdrop-blur-sm rounded-3xl p-12 flex flex-col justify-end border border-white/5 hover:border-academic-accent/20 hover:shadow-2xl hover:shadow-academic-accent/5 transition-all duration-700 group">
        <h2 class="text-xs font-black tracking-[0.3em] uppercase text-academic-accent mb-6 animate-pulse">Actualidad</h2>
        <h3 class="font-serif text-5xl md:text-6xl font-black text-white leading-tight tracking-tighter">
            Análisis & <br/><span class="text-academic-accent italic font-light">Perspectiva Crítica</span>
        </h3>
    </div>

    <div class="md:col-span-2 md:row-span-2 relative rounded-3xl overflow-hidden group shadow-2xl border border-white/20">
        <img src="/assets/original.jpeg" alt="Actualidad" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-academic-dark/90 via-academic-dark/20 to-transparent p-12 flex flex-col justify-end backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all duration-700">
            <span class="text-xs uppercase tracking-[0.2em] font-black text-academic-accent mb-4">Investigación en Foco</span>
            <h4 class="text-white text-3xl md:text-4xl font-serif font-black leading-[1.1] mb-8 tracking-tight">El impacto de los conflictos prolongados en la memoria colectiva.</h4>
            <a href="#" class="inline-flex items-center gap-4 text-white text-xs font-black uppercase tracking-[0.3em] border-b border-white/20 pb-2 w-max hover:border-academic-accent hover:text-academic-accent transition-all group/link">
                Leer Análisis Completo
                <i class="fa-solid fa-arrow-right-long transition-transform group-hover/link:translate-x-2"></i>
            </a>
        </div>
    </div>

    <div class="md:col-span-1 md:row-span-1 bg-academic-dark rounded-3xl p-8 flex flex-col justify-between text-white hover:bg-black transition-all duration-500 group/event">
        <div>
            <div class="flex items-center justify-between mb-8">
                <span class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center group-hover/event:bg-academic-accent/20 transition-colors">
                    <i class="fa-solid fa-calendar-star text-academic-accent"></i>
                </span>
                <span class="text-xs font-bold tracking-widest uppercase text-white/50">Agenda</span>
            </div>
            <p class="text-xl font-serif font-medium leading-snug">Seminario sobre Terrorismo de Estado</p>
        </div>
        <div class="flex items-end justify-between gap-2">
            <div class="flex items-baseline gap-2">
                <span class="text-4xl font-black text-academic-accent">15</span>
                <span class="text-xs uppercase font-bold tracking-widest text-white/50">Mayo</span>
            </div>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-academic-accent hover:border-academic-accent transition-all group/btn">
                <i class="fa-solid fa-arrow-up-right-from-square text-xs group-hover/btn:scale-110 transition-transform"></i>
            </a>
        </div>
    </div>

    <div class="md:col-span-1 md:row-span-1 bg-white/5 backdrop-blur-sm border border-white/5 rounded-3xl p-10 flex flex-col justify-center text-center relative overflow-hidden group/quote">
        <i class="fa-solid fa-quote-left text-academic-accent/10 text-6xl absolute top-8 left-8"></i>
        <p class="font-serif italic text-xl text-white/80 leading-relaxed relative z-10">
            "La historia no se repite, <br/>pero <span class="text-academic-accent not-italic font-black">rima</span> con la violencia del pasado."
        </p>
    </div>

    <div class="md:col-span-2 md:row-span-1 bg-white/[0.03] backdrop-blur-md rounded-3xl p-10 flex gap-8 items-center border border-white/5 overflow-hidden group/news">
        <div class="flex-1">
            <span class="text-xs font-black tracking-[0.2em] uppercase text-academic-accent block mb-6 px-1 border-l-2 border-academic-accent">Últimas Novedades</span>
            <ul class="space-y-6">
                <li class="news-item group cursor-pointer border-b border-white/5 pb-3 hover:border-academic-accent transition-colors" 
                    data-type="video" 
                    data-src="/assets/preview-entrevista.mp4" 
                    data-thumbnail="/assets/original.jpeg"
                    role="link"
                    aria-label="Ver entrevista en Radio Nacional (Video)">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-5">
                            <span class="text-[8px] uppercase font-black text-academic-accent bg-academic-accent/10 px-3 py-1 rounded-full border border-academic-accent/20">Video</span>
                            <span class="text-sm font-black tracking-widest text-white/70 uppercase group-hover:text-white transition-colors">Entrevista en Radio Nacional</span>
                        </div>
                        <i class="fa-solid fa-play text-xs text-academic-accent/40 opacity-0 group-hover:opacity-100 transition-all"></i>
                    </div>
                </li>
                <li class="news-item group cursor-pointer border-b border-white/5 pb-3 hover:border-academic-accent transition-colors" 
                    data-type="article"
                    role="link"
                    aria-label="Leer artículo: Perspectivas sobre la Paz">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-5">
                            <span class="text-[8px] uppercase font-black text-white/50 bg-white/5 px-3 py-1 rounded-full border border-white/10">Artículo</span>
                            <span class="text-sm font-black tracking-widest text-white/70 uppercase group-hover:text-white transition-colors">Perspectivas sobre la Paz</span>
                        </div>
                        <i class="fa-solid fa-arrow-right text-xs text-white/20 group-hover:text-academic-accent group-hover:translate-x-1 transition-all"></i>
                    </div>
                </li>
            </ul>
        </div>

        <div id="media-trigger" 
             class="hidden lg:flex flex-col items-center justify-center w-40 h-40 bg-gradient-to-br from-academic-dark to-slate-900 rounded-2xl shadow-2xl p-4 rotate-3 group-hover/news:rotate-0 transition-all duration-700 border border-white/5 relative overflow-hidden group/play"
             aria-hidden="true">
            
            <div id="thumbnail-bg" class="absolute inset-0 bg-cover bg-center opacity-0 transition-opacity duration-500 z-0"></div>
            
            <video id="preview-player" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 z-[1] pointer-events-none" muted loop playsinline>
                <source src="" type="video/mp4">
            </video>

            <div id="play-button-container" class="w-16 h-16 rounded-full bg-academic-dark flex items-center justify-center shadow-lg group-hover/play:scale-110 transition-all duration-500 relative z-10">
                <div id="pulse-ring" class="absolute inset-0 rounded-full bg-academic-accent animate-ping-slow opacity-0"></div>
                <i id="main-play-icon" class="fa-solid fa-play text-2xl text-white ml-1 transition-colors"></i>
            </div>
            
            <span id="media-label" class="mt-4 text-[8px] font-black uppercase tracking-[0.2em] text-white/50 opacity-0 group-hover/news:opacity-100 transition-all duration-1000 relative z-10">Explorar</span>
        </div>
    </div>
  </div>
</section>

<script>
  // Lógica de interacción dinámica
  const newsItems = document.querySelectorAll('.news-item');
  const player = document.getElementById('preview-player') as HTMLVideoElement;
  const thumbnailBg = document.getElementById('thumbnail-bg');
  const pulseRing = document.getElementById('pulse-ring');
  const playIcon = document.getElementById('main-play-icon');
  const playButtonContainer = document.getElementById('play-button-container');
  const mediaLabel = document.getElementById('media-label');

  newsItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      const type = item.getAttribute('data-type');
      const videoSrc = item.getAttribute('data-src');
      const thumbSrc = item.getAttribute('data-thumbnail');

      // 1. Resetear estados previos si es necesario (limpieza suave)
      if (player) {
          player.style.opacity = '0';
          player.pause();
      }
      if (thumbnailBg) thumbnailBg.style.opacity = '0';

      if (type === 'video') {
        // 2. Activar Thumbnail y Video Preview
        if (thumbSrc && thumbnailBg) {
            thumbnailBg.style.backgroundImage = `url('${thumbSrc}')`;
            thumbnailBg.style.opacity = '0.3';
        }
        
        if (videoSrc && player) {
            if (player.src !== videoSrc) {
                player.src = videoSrc;
                player.load();
            }
            player.style.opacity = '1';
            player.play().catch(() => {});
        }

        // 3. Feedback visual en el botón
        pulseRing?.classList.remove('opacity-0');
        pulseRing?.classList.add('opacity-40');
        playButtonContainer?.classList.add('bg-academic-accent');
        playIcon?.classList.remove('text-white');
        playIcon?.classList.add('text-academic-dark');
        
        if(mediaLabel) mediaLabel.textContent = "Ver Video";
      } else {
        // Para tipos que no son video, podemos elegir un estado por defecto o no hacer nada
        // Pero para cumplir con la petición de persistir hasta "otro diferente", no reseteamos a Explorar aquí.
        pulseRing?.classList.add('opacity-0');
        pulseRing?.classList.remove('opacity-40');
        playButtonContainer?.classList.remove('bg-academic-accent');
        playIcon?.classList.add('text-white');
        playIcon?.classList.remove('text-academic-dark');
        if(mediaLabel) mediaLabel.textContent = "Leer Más";
      }
    });
  });

  // Opcional: Resetear solo si sales del área del GRID completo para que no sea intrusivo
  const gridSection = document.querySelector('section');
  if (gridSection) {
    gridSection.addEventListener('mouseleave', () => {
        if (player) {
            player.style.opacity = '0';
            player.pause();
        }
        if (thumbnailBg) thumbnailBg.style.opacity = '0';
        pulseRing?.classList.add('opacity-0');
        pulseRing?.classList.remove('opacity-40');
        playButtonContainer?.classList.remove('bg-academic-accent');
        playIcon?.classList.add('text-white');
        playIcon?.classList.remove('text-academic-dark');
        if(mediaLabel) mediaLabel.textContent = "Explorar";
    });
  }
</script>

<style>
  .shadow-premium {
    box-shadow: 0 20px 50px -12px rgba(180, 140, 60, 0.15);
  }
  .animate-ping-slow {
    animation: ping 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>