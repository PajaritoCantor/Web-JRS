---
// EditorialGrid.astro
---
<section class="max-w-[1440px] mx-auto px-6 py-24">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[300px] md:auto-rows-[350px]">
    
    <!-- Bloque 1: Título Editorial -->
    <div class="md:col-span-2 md:row-span-1 bg-zinc-50 rounded-3xl p-12 flex flex-col justify-end border border-zinc-100 hover:shadow-premium transition-all duration-700 group">
        <h2 class="text-xs font-bold tracking-[0.4em] uppercase text-academic-accent mb-6 animate-pulse">Pulso Actual</h2>
        <h3 class="font-serif text-4xl md:text-5xl font-black text-academic-dark leading-tight">
            Análisis & <br/>Perspectiva Crítica
        </h3>
    </div>

    <!-- Bloque 2: Actualidad Destacada (Imagen) - Relacionado con Pulso Actual -->
    <div class="md:col-span-2 md:row-span-2 relative rounded-3xl overflow-hidden group shadow-premium">
        <img src="/assets/original.jpeg" alt="Actualidad" class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-academic-dark/90 via-academic-dark/20 to-transparent p-12 flex flex-col justify-end">
            <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/70 mb-4">Investigación en Foco</span>
            <h4 class="text-white text-2xl md:text-3xl font-serif font-bold leading-tight mb-6">El impacto de los conflictos prolongados en la memoria colectiva.</h4>
            <a href="#" class="text-white text-xs font-bold uppercase tracking-widest border-b border-white/30 pb-1 w-max hover:border-white transition-all">Leer Análisis Completo</a>
        </div>
    </div>

    <!-- Bloque 3: Evento Próximo -->
    <div class="md:col-span-1 md:row-span-1 bg-academic-dark rounded-3xl p-8 flex flex-col justify-between text-white hover:bg-black transition-all duration-500">
        <div>
            <div class="flex items-center justify-between mb-8">
                <span class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                    <i class="fa-solid fa-calendar-star text-academic-accent"></i>
                </span>
                <span class="text-[10px] font-bold tracking-widest uppercase text-white/50">Agenda</span>
            </div>
            <p class="text-xl font-serif font-medium leading-snug">Seminario sobre Terrorismo de Estado</p>
        </div>
        <div class="flex items-baseline gap-2">
            <span class="text-4xl font-black text-academic-accent">15</span>
            <span class="text-xs uppercase font-bold tracking-widest text-white/50">Mayo</span>
        </div>
    </div>

    <!-- Bloque 4: Cita / Pensamiento -->
    <div class="md:col-span-1 md:row-span-1 bg-white border border-zinc-100 rounded-3xl p-8 flex flex-col justify-center text-center">
        <i class="fa-solid fa-quote-left text-zinc-100 text-5xl mb-6"></i>
        <p class="font-serif italic text-lg text-academic-dark leading-relaxed">
            "La historia no se repite, pero rima con la violencia del pasado."
        </p>
    </div>

    <!-- Bloque 5: Últimas Novedades (Feed Mixto) -->
    <div class="md:col-span-2 md:row-span-1 bg-zinc-50 rounded-3xl p-8 flex gap-8 items-center border border-zinc-100 overflow-hidden">
        <div class="flex-1">
            <span class="text-[9px] font-black tracking-[0.3em] uppercase text-academic-muted block mb-4 italic">Últimas Novedades</span>
            <ul class="space-y-4">
                <li class="flex items-center justify-between group cursor-pointer border-b border-zinc-200/50 pb-2 hover:border-academic-accent transition-colors">
                    <div class="flex items-center gap-4">
                        <span class="text-[8px] uppercase font-black text-academic-accent border border-academic-accent/30 px-2 py-0.5 rounded">Video</span>
                        <span class="text-sm font-bold text-academic-dark group-hover:text-black">Entrevista en Radio Nacional</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px] text-zinc-300 group-hover:text-academic-accent transition-all"></i>
                </li>
                <li class="flex items-center justify-between group cursor-pointer border-b border-zinc-200/50 pb-2 hover:border-academic-accent transition-colors">
                    <div class="flex items-center gap-4">
                        <span class="text-[8px] uppercase font-black text-zinc-400 border border-zinc-300 px-2 py-0.5 rounded">Artículo</span>
                        <span class="text-sm font-bold text-academic-dark group-hover:text-black">Perspectivas sobre la Paz</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px] text-zinc-300 group-hover:text-academic-accent transition-all"></i>
                </li>
            </ul>
        </div>
        <div class="hidden lg:block w-32 h-32 bg-white rounded-2xl shadow-premium p-4 rotate-6 group-hover:rotate-0 transition-transform duration-700">
             <i class="fa-solid fa-play text-4xl text-zinc-100 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></i>
        </div>
    </div>

  </div>
</section>
