---
import ArticleItem from './ArticleItem.astro';

interface Article {
  id: number;
  titulo: string;
  revista: string;
  anio: number;
  url_externa: string;
  descripcion_corta?: string;
}

interface Props {
  limit?: number;
  showAllLink?: boolean;
  dark?: boolean;
}

const { limit, showAllLink = true, dark = false } = Astro.props as Props;

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? 'http://localhost:3000';
let articles: Article[] = [];

try {
  const response = await fetch(`${apiBase}/api/articles`);
  const body = await response.json();

  if (response.ok && Array.isArray(body.data)) {
    articles = body.data
      .map((item: any) => ({
        id: Number(item.id),
        titulo: item.titulo ?? item.title ?? '',
        revista: item.revista ?? item.journal ?? 'Publicacion academica',
        anio: Number(item.anio ?? item.year ?? 0),
        url_externa: item.url_externa ?? item.url ?? '',
        descripcion_corta: item.descripcion_corta ?? ''
      }))
      .filter((item: Article) => item.titulo && item.url_externa)
      .sort((a: Article, b: Article) => b.anio - a.anio);
  }
} catch {
  // Fallback silencioso para desarrollo sin backend.
}

if (articles.length === 0) {
  articles = [
    {
      id: 1,
      titulo: 'Dinamicas contemporaneas de violencia politica en Iberoamerica',
      revista: 'Revista de Estudios Estrategicos',
      anio: 2024,
      url_externa: 'https://example.org/articulo-1',
      descripcion_corta: 'Revision comparada sobre repertorios de accion armada y respuestas estatales en el siglo XXI.'
    },
    {
      id: 2,
      titulo: 'Insurgencia, territorio y gobernanza local en Colombia',
      revista: 'Journal of Conflict and Society',
      anio: 2022,
      url_externa: 'https://example.org/articulo-2',
      descripcion_corta: 'Analisis del vinculo entre control territorial, legitimidad y construccion de paz subnacional.'
    },
    {
      id: 3,
      titulo: 'Negociacion politica y desmovilizacion comparada',
      revista: 'Anuario Iberoamericano de Seguridad',
      anio: 2021,
      url_externa: 'https://example.org/articulo-3',
      descripcion_corta: 'Lecciones comparativas sobre procesos de desarme, reintegracion y estabilizacion institucional.'
    }
  ];
}

const visibleArticles = typeof limit === 'number' ? articles.slice(0, limit) : articles;
---

<section id="articulos" class:list={[
  "relative w-full py-16 lg:py-24 overflow-hidden transition-colors duration-500",
  "bg-academic-dark text-white"
]}>
  <div class="absolute inset-0 opacity-10 -z-10" style="background-image: radial-gradient(rgba(251,191,36,0.1) 1px, transparent 1px); background-size: 30px 30px;"></div>
  <div class="absolute -top-20 -right-20 w-[60%] h-[60%] bg-academic-accent/5 blur-[120px] rounded-full -z-10"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start">
      <div class="lg:col-span-4">
        <div class="flex items-center gap-3 mb-5">
          <span class:list={["h-1 w-10", dark ? "bg-academic-accent/60" : "bg-blue-900/60"]}></span>
          <span class:list={["text-xs font-bold tracking-[0.2em] uppercase", dark ? "text-academic-accent/70" : "text-blue-900/70"]}>Publicaciones</span>
        </div>

        <h2 class="font-serif text-4xl lg:text-6xl font-black leading-[0.9] text-white italic">
          Artículos de <br/>
          <span class="not-italic text-white/90 underline decoration-academic-accent decoration-2 underline-offset-8">Investigación</span>
        </h2>

        <p class:list={[
          "mt-5 leading-relaxed font-sans text-base",
          dark ? "text-white/60" : "text-slate-700"
        ]}>
          Índice académico cronológico con acceso a fuentes originales y metadatos editoriales.
        </p>

        {showAllLink && (
          <a href="/publicaciones/articulos" class:list={[
            "inline-flex items-center gap-2 mt-7 rounded-full border px-5 py-2.5 font-sans text-[10px] tracking-[0.18em] uppercase font-black transition-colors duration-300",
            dark ? "border-white/10 bg-white/5 text-white/70 hover:border-white/30 hover:text-white" : "border-slate-300/70 bg-white/80 text-slate-700 hover:border-blue-900/30 hover:text-blue-900"
          ]}>
            Ver todos
            <i class="fa-solid fa-arrow-right text-[10px]" aria-hidden="true"></i>
          </a>
        )}
      </div>

      <div class="lg:col-span-8 space-y-4">
        {visibleArticles.map((article) => (
          <ArticleItem
            titulo={article.titulo}
            revista={article.revista}
            anio={article.anio}
            urlExterna={article.url_externa}
            descripcionCorta={article.descripcion_corta}
            dark={dark}
          />
        ))}
      </div>
    </div>
  </div>
</section>
