---
// Footer Component
const currentYear = new Date().getFullYear();
---
<footer class="w-full bg-academic-dark text-white py-20 mt-20">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-24 mb-16">
      
      <!-- Brand -->
      <div class="col-span-1 md:col-span-1">
        <h2 class="font-serif text-3xl font-bold mb-6 tracking-tight">Jerónimo Ríos</h2>
        <p class="text-zinc-400 text-sm leading-relaxed max-w-sm mb-8">
          Investigación académica dedicada al análisis de conflictos armados, terrorismo de estado y política en Iberoamérica.
        </p>
        <div class="flex space-x-6 text-zinc-400">
          <a href="#" aria-label="X" class="hover:text-white transition-colors text-xl"><i class="fa-brands fa-x-twitter"></i></a>
          <a href="#" aria-label="LinkedIn" class="hover:text-white transition-colors text-xl"><i class="fa-brands fa-linkedin"></i></a>
          <a href="#" aria-label="Instagram" class="hover:text-white transition-colors text-xl"><i class="fa-brands fa-instagram"></i></a>
          <a href="mailto:info@jeronimorios.com" aria-label="Gmail" class="hover:text-white transition-colors text-xl"><i class="fa-solid fa-envelope"></i></a>
        </div>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-2 gap-12 col-span-1 md:col-span-2">
        <div>
          <h4 class="text-[10px] uppercase tracking-[0.3em] font-bold mb-8 text-academic-accent">Explora</h4>
          <ul class="space-y-4 text-sm font-medium text-zinc-400">
            <li><a href="/biografia" class="hover:text-white transition-colors">Biografía</a></li>
            <li><a href="/publicaciones/articulos" class="hover:text-white transition-colors">Artículos</a></li>
            <li><a href="/publicaciones/libros" class="hover:text-white transition-colors">Libros</a></li>
            <li><a href="#" class="hover:text-white transition-colors">Medios</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[10px] uppercase tracking-[0.3em] font-bold mb-8 text-academic-accent">Contacto</h4>
          <ul class="space-y-4 text-sm font-medium text-zinc-400">
            <li><a href="mailto:info@jeronimorios.com" class="hover:text-white transition-colors">info@jeronimorios.com</a></li>
            <li><span class="block">Madrid, España</span></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-zinc-800 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-zinc-500 text-[10px] uppercase tracking-[0.2em] font-bold">
        © {new Date().getFullYear()} Jerónimo Ríos Sierra. Todos los derechos reservados.
      </p>
      <div class="flex gap-8 text-zinc-500 text-[10px] uppercase tracking-[0.2em] font-bold">
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Legal</a>
      </div>
    </div>
  </div>
</footer>
