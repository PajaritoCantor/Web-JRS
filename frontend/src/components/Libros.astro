const destacado = publicaciones.find(p => p.featured);
const listaSecundaria = publicaciones.filter(p => !p.featured);
---

<section id="libros" class="w-full bg-academic-dark text-white py-32 overflow-hidden">
    <div class="container mx-auto px-6">
        
        <div class="flex flex-col md:flex-row items-end justify-between mb-24 gap-12">
            <div class="max-w-2xl">
                <h2 class="text-xs font-black tracking-[0.5em] uppercase text-academic-accent mb-8">Obras de Referencia</h2>
                <h3 class="font-serif text-5xl md:text-7xl font-black leading-tight">Publicaciones <br/><span class="text-slate-400 italic font-light">Destacadas</span></h3>
            </div>
            <div class="md:text-right">
                <p class="text-white/80 font-medium text-lg max-w-sm mb-8 italic">
                    Análisis críticos y revisiones históricas sobre la violencia y la paz en Iberoamérica.
                </p>
                {showAllLink && (
                    <a href="/publicaciones/libros" class="inline-flex items-center gap-4 text-xs font-black tracking-widest uppercase text-white hover:text-academic-accent transition-colors group">
                        Ver Catálogo Completo
                        <i class="fa-solid fa-arrow-right-long group-hover:translate-x-2 transition-transform"></i>
                    </a>
                )}
            </div>
        </div>

        {!hideFeatured && destacado && (
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center mb-32 group book-card" data-tipo={destacado.tipo}>
                <div class="lg:col-span-1 text-[12rem] font-black text-white/5 leading-none hidden lg:block select-none transform -rotate-90">01</div>
                <div class="lg:col-span-5 relative aspect-[3/4] overflow-hidden rounded-3xl bg-white/5 p-12 border border-white/10">
                    <img src={destacado.imagen} alt={destacado.titulo} class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] group-hover:scale-105 transition-transform duration-1000" />
                </div>
                <div class="lg:col-span-6 flex flex-col justify-center">
                    <span class="text-academic-accent text-[11px] font-black tracking-[0.4em] uppercase mb-10 block">Último Lanzamiento 2025</span>
                    <h4 class="font-serif text-4xl md:text-6xl font-black mb-8 leading-tight">{destacado.titulo}</h4>
                    <p class="text-slate-400 text-xl leading-relaxed mb-12 max-w-xl font-light">
                        {destacado.subtitulo}
                    </p>
                    <div class="flex gap-10">
                        <a href={destacado.url} target="_blank" rel="noopener noreferrer" class="bg-white text-academic-dark px-10 py-4 rounded-full text-[10px] font-black tracking-widest uppercase hover:bg-academic-accent hover:text-white transition-all duration-500 shadow-xl shadow-black/20">
                            Adquirir Obra
                        </a>
                    </div>
                </div>
            </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12" id="books-grid">
            {listaSecundaria.map((pub) => (
                <a href={pub.url} target="_blank" rel="noopener noreferrer" class="group block book-card h-full" data-tipo={pub.tipo}>
                    <div class={`relative aspect-[3/4] rounded-2xl overflow-hidden mb-8 border border-white/10 transition-all duration-700 shadow-lg group-hover:shadow-2xl ${(pub.tipo === 'capitulo' && !pub.imagen) ? 'bg-gradient-to-br from-academic-accent/20 to-academic-dark flex items-center justify-center p-10 text-center' : 'bg-white/5'}`}>
                        
                        {pub.tipo === 'capitulo' && !pub.imagen ? (
                            <div class="group-hover:scale-105 transition-transform duration-500">
                                <i class="fa-solid fa-file-lines text-academic-accent/30 text-5xl mb-6"></i>
                                <h6 class="font-serif text-lg leading-snug px-4 italic">{pub.titulo}</h6>
                                <span class="block mt-4 text-[9px] font-black tracking-widest text-academic-accent uppercase italic">Capítulo de Libro</span>
                            </div>
                        ) : (
                            <>
                                <img src={pub.imagen} alt={pub.titulo} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-110" />
                                <div class="absolute inset-0 bg-gradient-to-t from-academic-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
                                    <p class="text-white/80 text-sm italic mb-6 line-clamp-3">"{pub.subtitulo}"</p>
                                    <span class="text-academic-accent border-b border-academic-accent text-[10px] font-black tracking-widest uppercase w-fit">Ver Publicación</span>
                                </div>
                            </>
                        )}
                    </div>
                    <h5 class="font-serif text-xl font-bold mb-3 group-hover:text-academic-accent transition-colors leading-tight">{pub.titulo}</h5>
                    <div class="flex items-center justify-between border-t border-white/5 pt-4">
                        <p class="text-white/40 text-[10px] font-black tracking-widest uppercase">{pub.año}</p>
                        <span class="text-white/20 text-[10px] uppercase tracking-wider font-medium">{pub.editorial}</span>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .filter-btn.active {
        @apply bg-academic-accent border-academic-accent text-white;
    }
    
    .book-card.hidden {
        display: none;
    }
</style>

<script>
    const filterButtons = document.querySelectorAll('.filter-btn');
    const bookCards = document.querySelectorAll('.book-card[data-tipo]');

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            // Update active state
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const filter = btn.getAttribute('data-filter');

            bookCards.forEach(card => {
                const tipo = card.getAttribute('data-tipo');
                if (filter === 'all' || tipo === filter) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        });
    });
</script>