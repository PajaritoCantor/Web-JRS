---
// Libros Component
---
<section id="libros" class="w-full bg-academic-dark text-white py-32 overflow-hidden">
    <div class="container mx-auto px-6">
        
        <div class="flex flex-col md:flex-row items-end justify-between mb-24 gap-12">
            <div class="max-w-2xl">
                <h2 class="text-xs font-black tracking-[0.5em] uppercase text-academic-accent mb-8">Obras de Referencia</h2>
                <h3 class="font-serif text-5xl md:text-7xl font-black leading-tight">Publicaciones <br/><span class="text-white/20 italic font-light">Destacadas</span></h3>
            </div>
            <div class="md:text-right">
                <p class="text-white/40 font-medium text-lg max-w-sm mb-8">
                    Análisis críticos y revisiones históricas sobre la violencia en Iberoamérica.
                </p>
                <a href="#" class="inline-flex items-center gap-4 text-xs font-black tracking-widest uppercase text-white hover:text-academic-accent transition-colors group">
                    Ver Catálogo Completo
                    <i class="fa-solid fa-arrow-right-long group-hover:translate-x-2 transition-transform"></i>
                </a>
            </div>
        </div>

        <!-- Fila Destacada: El Libro Principal -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center mb-32 group">
            <div class="lg:col-span-1 text-[12rem] font-black text-white/5 leading-none hidden lg:block select-none transform -rotate-90">01</div>
            <div class="lg:col-span-5 relative aspect-[3/4] overflow-hidden rounded-3xl bg-white/5 p-12">
                <img src="/assets/Brevehistoriadelconflicto.jpg" alt="Última Publicación" class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] group-hover:scale-105 transition-transform duration-1000" />
            </div>
            <div class="lg:col-span-6 flex flex-col justify-center">
                <span class="text-academic-accent text-[11px] font-black tracking-[0.4em] uppercase mb-10">Última Lanzamiento</span>
                <h4 class="font-serif text-4xl md:text-6xl font-black mb-8 leading-tight">Breve Historia del Conflicto Armado</h4>
                <p class="text-white/60 text-xl leading-relaxed mb-12 max-w-xl">
                    Un viaje a través de las raíces de la insurgencia y la respuesta estatal, desgranando la complejidad de la guerra en el siglo XXI.
                </p>
                <div class="flex gap-10">
                    <button class="bg-white text-academic-dark px-10 py-4 rounded-full text-xs font-black tracking-widest uppercase hover:bg-academic-accent hover:text-white transition-all duration-500">Adquirir Copia</button>
                    <button class="text-white border-b border-white/20 pb-2 text-xs font-black tracking-widest uppercase hover:border-academic-accent transition-all">Más Detalles</button>
                </div>
            </div>
        </div>

        <!-- Grilla de Obras Secundarias -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
            
            <a href="#" class="group block">
                <div class="aspect-[4/5] bg-white/5 rounded-2xl overflow-hidden mb-8 p-8 flex items-center justify-center border border-white/5 group-hover:border-academic-accent/30 transition-all duration-700">
                    <img src="/assets/TerrorismodeEstadoyGruposArmadosEnPeruArticle.jpeg" alt="Libro" class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-700" />
                </div>
                <h5 class="font-serif text-2xl font-bold mb-3">Terrorismo de Estado</h5>
                <p class="text-white/30 text-xs font-black tracking-widest uppercase">2021</p>
            </a>

            <a href="#" class="group block translate-y-12">
                <div class="aspect-[4/5] bg-white/5 rounded-2xl overflow-hidden mb-8 p-8 flex items-center justify-center border border-white/5 group-hover:border-academic-accent/30 transition-all duration-700">
                    <img src="/assets/1000x1000.jpg" alt="Libro" class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-700" />
                </div>
                <h5 class="font-serif text-2xl font-bold mb-3">Análisis Político</h5>
                <p class="text-white/30 text-xs font-black tracking-widest uppercase">2019</p>
            </a>

            <a href="#" class="group block">
                <div class="aspect-[4/5] bg-white/5 rounded-2xl overflow-hidden mb-8 p-8 flex items-center justify-center border border-white/5 group-hover:border-academic-accent/30 transition-all duration-700">
                    <img src="/assets/TerrorismodeEstadoyGruposArmadosEnPeruArticle.jpeg" alt="Libro" class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-700" />
                </div>
                <h5 class="font-serif text-2xl font-bold mb-3">Seguridad Global</h5>
                <p class="text-white/30 text-xs font-black tracking-widest uppercase">2016</p>
            </a>

        </div>
    </div>
</section>
