---
// Libros Component
interface Props {
    showAllLink?: boolean;
    hideFeatured?: boolean;
}

const { showAllLink = true, hideFeatured = false } = Astro.props;
---
<section id="libros" class="w-full bg-academic-dark text-white py-32 overflow-hidden">
    <div class="container mx-auto px-6">
        
        <div class="flex flex-col md:flex-row items-end justify-between mb-24 gap-12">
            <div class="max-w-2xl">
                <h2 class="text-xs font-black tracking-[0.5em] uppercase text-academic-accent mb-8">Obras de Referencia</h2>
                <h3 class="font-serif text-5xl md:text-7xl font-black leading-tight">Publicaciones <br/><span class="text-slate-400 italic font-light">Destacadas</span></h3>
            </div>
            <div class="md:text-right">
                <p class="text-white/80 font-medium text-lg max-w-sm mb-8">
                    Análisis críticos y revisiones históricas sobre la violencia en Iberoamérica.
                </p>
                {showAllLink && (
                    <a href="/publicaciones/libros" class="inline-flex items-center gap-4 text-xs font-black tracking-widest uppercase text-white hover:text-academic-accent transition-colors group">
                        Ver Catálogo Completo
                        <i class="fa-solid fa-arrow-right-long group-hover:translate-x-2 transition-transform"></i>
                    </a>
                )}
            </div>
        </div>

        {!hideFeatured && (
        <!-- Fila Destacada: El Libro Principal -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center mb-32 group book-card" data-category="monografia">
            <div class="lg:col-span-1 text-[12rem] font-black text-white/5 leading-none hidden lg:block select-none transform -rotate-90">01</div>
            <div class="lg:col-span-5 relative aspect-[3/4] overflow-hidden rounded-3xl bg-white/5 p-12">
                <img src="/assets/Brevehistoriadelconflicto.jpg" alt="Última Publicación" class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] group-hover:scale-105 transition-transform duration-1000" />
            </div>
            <div class="lg:col-span-6 flex flex-col justify-center">
                <span class="text-academic-accent text-[11px] font-black tracking-[0.4em] uppercase mb-10">Última Lanzamiento</span>
                <h4 class="font-serif text-4xl md:text-6xl font-black mb-8 leading-tight">Breve Historia del Conflicto Armado</h4>
                <p class="text-slate-400 text-xl leading-relaxed mb-12 max-w-xl font-light">
                    Un viaje a través de las raíces de la insurgencia y la respuesta estatal, desgranando la complejidad de la guerra en el siglo XXI.
                </p>
                <div class="flex gap-10">
                    <button class="bg-white text-academic-dark px-10 py-3 rounded-full text-[10px] font-black tracking-widest uppercase hover:bg-academic-accent hover:text-white transition-all duration-500">Adquirir Copia</button>
                    <button class="text-white border-b border-white/20 pb-2 text-[10px] font-black tracking-widest uppercase hover:border-academic-accent transition-all">Más Detalles</button>
                </div>
            </div>
        </div>
        )}

        <!-- Grilla de Obras Secundarias -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            
            <!-- Veinticinco años de posconflicto en Perú -->
            <a href="https://www.cepc.gob.es/publicaciones/monografias/veinticinco-anos-de-posconflicto-en-peru-avances-y-limites-en-la-implementacion-de-las-politicas-de" target="_blank" rel="noopener noreferrer" class="group block book-card" data-category="monografia">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-white/10 to-white/5 border border-white/10 group-hover:border-academic-accent/40 transition-all duration-700 shadow-lg group-hover:shadow-2xl group-hover:shadow-academic-accent/20">
                    <img src="/assets/original.jpeg" alt="Veinticinco años de posconflicto en Perú" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                    
                    <!-- Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-academic-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="inline-block bg-academic-accent text-academic-dark text-[9px] font-black tracking-widest uppercase px-3 py-1 rounded-full w-fit mb-4">Justicia Transicional</span>
                        <p class="text-white/80 text-sm leading-relaxed mb-6">Análisis crítico sobre la implementación de políticas de reparación y memoria en el Perú contemporáneo.</p>
                        <button class="text-academic-accent border-b border-academic-accent text-[10px] font-black tracking-widest uppercase hover:text-white hover:border-white transition-all">Ver Publicación</button>
                    </div>
                </div>
                <h5 class="font-serif text-xl font-bold mb-2 group-hover:text-academic-accent transition-colors leading-tight">Veinticinco años de posconflicto en Perú</h5>
                <div class="flex items-center justify-between">
                    <p class="text-slate-500 text-xs font-black tracking-widest uppercase">2025</p>
                    <span class="text-slate-500 text-xs uppercase tracking-wider">CEPC</span>
                </div>
            </a>
            
            <!-- Libro 1 -->
            <a href="#" class="group block book-card" data-category="monografia">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-white/10 to-white/5 border border-white/10 group-hover:border-academic-accent/40 transition-all duration-700 shadow-lg group-hover:shadow-2xl group-hover:shadow-academic-accent/20">
                    <img src="/assets/TerrorismodeEstadoyGruposArmadosEnPeruArticle.jpeg" alt="Terrorismo de Estado" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                    
                    <!-- Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-academic-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="inline-block bg-academic-accent text-academic-dark text-[9px] font-black tracking-widest uppercase px-3 py-1 rounded-full w-fit mb-4">Teoría Política</span>
                        <p class="text-white/80 text-sm leading-relaxed mb-6">Análisis crítico de la represión estatal y sus mecanismos de control territorial.</p>
                        <button class="text-academic-accent border-b border-academic-accent text-[10px] font-black tracking-widest uppercase hover:text-white hover:border-white transition-all">Ver Detalles</button>
                    </div>
                </div>
                <h5 class="font-serif text-xl font-bold mb-2 group-hover:text-academic-accent transition-colors">Terrorismo de Estado</h5>
                <div class="flex items-center justify-between">
                    <p class="text-slate-500 text-xs font-black tracking-widest uppercase">2021</p>
                    <span class="text-slate-500 text-xs uppercase tracking-wider">Editorial UCM</span>
                </div>
            </a>

            <!-- Libro 2 -->
            <a href="#" class="group block book-card" data-category="coordinado">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-white/10 to-white/5 border border-white/10 group-hover:border-academic-accent/40 transition-all duration-700 shadow-lg group-hover:shadow-2xl group-hover:shadow-academic-accent/20">
                    <img src="/assets/1000x1000.jpg" alt="Análisis Político" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                    
                    <!-- Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-academic-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="inline-block bg-academic-accent text-academic-dark text-[9px] font-black tracking-widest uppercase px-3 py-1 rounded-full w-fit mb-4">Geopolítica</span>
                        <p class="text-white/80 text-sm leading-relaxed mb-6">Interpretación de las dinámicas políticas contemporáneas en contextos de transformación global.</p>
                        <button class="text-academic-accent border-b border-academic-accent text-[10px] font-black tracking-widest uppercase hover:text-white hover:border-white transition-all">Ver Detalles</button>
                    </div>
                </div>
                <h5 class="font-serif text-xl font-bold mb-2 group-hover:text-academic-accent transition-colors">Análisis Político Contemporáneo</h5>
                <div class="flex items-center justify-between">
                    <p class="text-white/40 text-xs font-black tracking-widest uppercase">2019</p>
                    <span class="text-white/20 text-xs uppercase tracking-wider">Comares</span>
                </div>
            </a>

            <!-- Libro 3 -->
            <a href="#" class="group block book-card" data-category="monografia">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-white/10 to-white/5 border border-white/10 group-hover:border-academic-accent/40 transition-all duration-700 shadow-lg group-hover:shadow-2xl group-hover:shadow-academic-accent/20">
                    <img src="/assets/TerrorismodeEstadoyGruposArmadosEnPeruArticle.jpeg" alt="Seguridad Global" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                    
                    <!-- Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-academic-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="inline-block bg-academic-accent text-academic-dark text-[9px] font-black tracking-widest uppercase px-3 py-1 rounded-full w-fit mb-4">Seguridad</span>
                        <p class="text-white/80 text-sm leading-relaxed mb-6">Perspectiva integral sobre amenazas transnacionales y cooperación en seguridad multisectorial.</p>
                        <button class="text-academic-accent border-b border-academic-accent text-[10px] font-black tracking-widest uppercase hover:text-white hover:border-white transition-all">Ver Detalles</button>
                    </div>
                </div>
                <h5 class="font-serif text-xl font-bold mb-2 group-hover:text-academic-accent transition-colors">Seguridad Global e Iberoamérica</h5>
                <div class="flex items-center justify-between">
                    <p class="text-slate-500 text-xs font-black tracking-widest uppercase">2016</p>
                    <span class="text-slate-500 text-xs uppercase tracking-wider">Springer</span>
                </div>
            </a>

        </div>
    </div>
</section>
