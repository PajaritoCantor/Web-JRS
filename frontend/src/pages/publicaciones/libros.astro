---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Libros from '../../components/Libros.astro';
---

<Layout title="Catálogo de Publicaciones | Jerónimo Ríos">
  <main class="w-full flex-grow bg-academic-dark min-h-screen">
    <!-- Hero Section para el Catálogo -->
    <section class="pt-40 pb-20 bg-academic-dark text-white border-b border-white/5 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-academic-accent/5 to-transparent"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-4xl">
                <span class="text-academic-accent text-[10px] font-black tracking-[0.5em] uppercase mb-8 block px-1 border-l-2 border-academic-accent">Biblioteca Académica</span>
                <h1 class="font-serif text-6xl md:text-9xl font-black mb-10 leading-none tracking-tighter">Obra <br/><span class="text-white/20 italic font-light">Completa</span></h1>
                <p class="text-white/60 text-xl md:text-2xl leading-relaxed max-w-2xl font-light">
                    Una recopilación exhaustiva de monografías, libros colectivos y ediciones críticas sobre el conflicto armado y la política en Iberoamérica.
                </p>
            </div>
        </div>
    </section>

    <!-- Filtros Sugeridos (Visual) -->
    <section class="py-10 bg-academic-dark/80 sticky top-0 z-50 backdrop-blur-xl border-b border-white/10">
        <div class="container mx-auto px-6 flex flex-wrap items-center justify-between gap-8">
            <div class="flex gap-8">
                <button class="text-academic-accent border-b-2 border-academic-accent pb-2 text-xs font-black tracking-widest uppercase">Todos</button>
                <button class="text-white/30 hover:text-white transition-colors pb-2 text-xs font-black tracking-widest uppercase">Monografías</button>
                <button class="text-white/30 hover:text-white transition-colors pb-2 text-xs font-black tracking-widest uppercase">Coordinados</button>
            </div>
            <div class="relative w-full md:w-96 group">
                <input type="text" placeholder="BUSCAR POR TÍTULO O AÑO..." class="w-full bg-white/5 border border-white/10 rounded-full py-4 px-8 text-[11px] tracking-widest text-white placeholder:text-white/20 focus:outline-none focus:border-academic-accent/50 transition-all font-medium" />
                <i class="fa-solid fa-magnifying-glass absolute right-8 top-1/2 -translate-y-1/2 text-white/20 text-sm group-focus-within:text-academic-accent transition-colors"></i>
            </div>
        </div>
    </section>

    <!-- Sección de Libros (Componente Reutilizado) -->
    <Libros showAllLink={false} />
    
    <!-- Sección Adicional sugerida: Próximos Lanzamientos -->
    <section class="py-40 bg-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                <div>
                     <span class="text-academic-accent text-[10px] font-black tracking-[0.4em] uppercase mb-6 block">En Desarrollo</span>
                    <h4 class="font-serif text-5xl md:text-6xl font-black mb-10 text-white italic">Próximos <br/>Lanzamientos</h4>
                    <p class="text-white/50 text-lg leading-relaxed mb-12 max-w-lg">
                        Actualmente trabajando en nuevas investigaciones que abordan la evolución de las insurgencias y los desafíos de la paz territorial.
                    </p>
                </div>
                
                <div class="relative group">
                    <div class="absolute -inset-4 bg-academic-accent/10 rounded-[40px] blur-2xl group-hover:bg-academic-accent/20 transition-all duration-700"></div>
                    <div class="relative p-12 rounded-[40px] border border-white/10 bg-academic-dark/60 backdrop-blur-md shadow-3xl">
                        <span class="text-academic-accent text-[9px] font-black tracking-[0.4em] uppercase mb-6 block">Publicación Estimada 2025</span>
                        <h5 class="text-3xl font-serif font-black mb-6 text-white">Geopolítica de la Insurgencia en el Siglo XXI</h5>
                        <p class="text-white/40 text-base leading-relaxed mb-10 font-light italic">
                            "Un estudio profundo sobre las nuevas formas de territorialidad armada y la erosión de la soberanía estatal en las periferias globales..."
                        </p>
                        <div class="flex items-center gap-6">
                            <button class="bg-white text-academic-dark px-8 py-3 rounded-full text-[10px] font-black tracking-widest uppercase hover:bg-academic-accent hover:text-white transition-all duration-500 shadow-lg">Notificarme</button>
                            <span class="text-white/20 text-[10px] uppercase tracking-widest font-black">Editorial Comares</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Elementos Decorativos -->
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-academic-accent/10 rounded-full blur-[100px]"></div>
    </section>

    <Footer />
  </main>
</Layout>

<style>
    /* Estilos personalizados para la tipografía si es necesario */
    main {
        font-family: 'Inter', system-ui, sans-serif;
    }
    h1, h2, h3, h4, h5 {
        font-family: 'Playfair Display', serif; /* O la que use el proyecto */
    }
</style>
