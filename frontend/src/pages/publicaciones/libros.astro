---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Libros from '../../components/Libros.astro';
---

<Layout title="Catálogo de Publicaciones | Jerónimo Ríos">
  <main class="w-full flex-grow bg-academic-dark min-h-screen">
    
    <!-- Hero Spotlight: Último Lanzamiento (Efecto Galería de Arte) -->
    <section class="pt-48 pb-32 bg-academic-dark relative overflow-hidden">
        <!-- Fondos Atmosféricos -->
        <div class="absolute top-0 right-0 w-[60%] h-full bg-academic-accent/5 blur-[150px] -z-10 animate-pulse-slow"></div>
        <div class="absolute -bottom-[20%] -left-[10%] w-[50%] h-[50%] bg-blue-900/10 blur-[150px] -z-10"></div>

        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                
                <!-- Info del Libro -->
                <div class="relative z-10 order-2 lg:order-1 text-center lg:text-left">
                    <span class="inline-block text-academic-accent text-[10px] font-black tracking-[0.5em] uppercase mb-10 border-l-2 border-academic-accent pl-6">Último Lanzamiento</span>
                    <h1 class="font-serif text-6xl md:text-8xl font-black mb-10 leading-[0.9] tracking-tighter text-white">
                        Tupamaros <br/><span class="text-slate-400 italic font-light">en Uruguay</span>
                    </h1>
                    <p class="text-white/60 text-xl leading-relaxed mb-12 max-w-xl font-light mx-auto lg:mx-0">
                        Orígenes, evolución y relaciones internacionales de la guerrilla urbana (1962-1976). Una investigación definitiva sobre la insurgencia regional.
                    </p>
                    <div class="flex flex-wrap justify-center lg:justify-start gap-8 items-center">
                        <a href="https://www.comares.com/libro/tupamaros-en-uruguay_165135/" target="_blank" class="bg-white text-academic-dark px-12 py-5 rounded-full text-[11px] font-black tracking-[0.2em] uppercase hover:bg-academic-accent hover:text-white transition-all duration-700 shadow-2xl hover:scale-105 active:scale-95">Adquirir Obra</a>
                        <span class="text-white/20 text-[10px] uppercase tracking-widest font-black border border-white/10 px-6 py-2 rounded-full">Editorial Comares</span>
                    </div>
                </div>

                <!-- Visualización del Libro (Efecto 3D/Sombra) -->
                <div class="relative z-10 order-1 lg:order-2 flex justify-center perspective-1000">
                    <div class="relative group">
                        <div class="absolute -inset-10 bg-academic-accent/10 rounded-full blur-[100px] animate-pulse"></div>
                        <img 
                            src="/assets/covers/tupamaros.jpg" 
                            alt="Portada Tupamaros en Uruguay" 
                            class="w-[300px] md:w-[450px] relative z-10 rounded-[5px] shadow-[20px_40px_80px_-15px_rgba(0,0,0,0.8)] transform rotate-y-12 rotate-x-6 hover:rotate-0 transition-all duration-1000 ease-out cursor-pointer hover:scale-105"
                        />
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Barra de Filtros (Inspirada en articulos.astro) -->
    <section class="py-10 bg-academic-dark/95 sticky top-0 z-50 backdrop-blur-xl border-b border-white/10">
        <div class="container mx-auto px-6 flex flex-wrap items-center justify-between gap-8">
            <div class="flex gap-8 filter-container">
                <button data-filter="all" class="filter-btn active text-academic-accent border-b-2 border-academic-accent pb-2 text-xs font-black tracking-widest uppercase transition-all">Todos</button>
                <button data-filter="monografia" class="filter-btn text-white/30 hover:text-white pb-2 text-xs font-black tracking-widest uppercase transition-all">Monografías</button>
                <button data-filter="coordinado" class="filter-btn text-white/30 hover:text-white pb-2 text-xs font-black tracking-widest uppercase transition-all">Coordinados</button>
            </div>
            <div class="relative w-full md:w-96 group">
                <input type="text" id="bookSearch" placeholder="BUSCAR POR TÍTULO O AÑO..." class="w-full bg-white/5 border border-white/10 rounded-full py-4 px-8 text-[11px] tracking-widest text-white placeholder:text-white/20 focus:outline-none focus:border-academic-accent/50 transition-all font-medium" />
                <i class="fa-solid fa-magnifying-glass absolute right-8 top-1/2 -translate-y-1/2 text-white/20 text-sm group-focus-within:text-academic-accent transition-colors"></i>
            </div>
        </div>
    </section>

    <!-- Sección de Libros con el destacado oculto -->
    <div class="pt-24">
        <Libros showAllLink={false} hideFeatured={true} />
    </div>

    <!-- Sección Adicional sugerida: Próximos Lanzamientos -->
    <section class="py-40 bg-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
                <div>
                     <span class="text-academic-accent text-[10px] font-black tracking-[0.4em] uppercase mb-6 block">En Desarrollo</span>
                    <h4 class="font-serif text-5xl md:text-6xl font-black mb-10 text-white italic">Próximos <br/>Lanzamientos</h4>
                    <p class="text-white/50 text-lg leading-relaxed mb-12 max-w-lg">
                        Actualmente trabajando en nuevas investigaciones que abordan la evolución de las insurgencias y los desafíos de la paz territorial.
                    </p>
                </div>
                
                <div class="relative group">
                    <div class="absolute -inset-4 bg-academic-accent/10 rounded-[40px] blur-2xl group-hover:bg-academic-accent/20 transition-all duration-700"></div>
                    <div class="relative p-12 rounded-[40px] border border-white/10 bg-academic-dark/60 backdrop-blur-md shadow-3xl">
                        <span class="text-academic-accent text-[9px] font-black tracking-[0.4em] uppercase mb-6 block">Publicación Estimada 2025</span>
                        <h5 class="text-3xl font-serif font-black mb-6 text-white">Geopolítica de la Insurgencia en el Siglo XXI</h5>
                        <p class="text-white/40 text-base leading-relaxed mb-10 font-light italic">
                            "Un estudio profundo sobre las nuevas formas de territorialidad armada y la erosión de la soberanía estatal en las periferias globales..."
                        </p>
                        <div class="flex items-center gap-6">
                            <button class="bg-white text-academic-dark px-8 py-3 rounded-full text-[10px] font-black tracking-widest uppercase hover:bg-academic-accent hover:text-white transition-all duration-500 shadow-lg">Notificarme</button>
                            <span class="text-white/20 text-[10px] uppercase tracking-widest font-black">Editorial Comares</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Elementos Decorativos -->
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-academic-accent/10 rounded-full blur-[100px]"></div>
    </section>

    <!-- CTA: Ir a Videos -->
    <section class="py-24 border-t border-white/5 bg-academic-dark/40 overflow-hidden relative">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-academic-accent/5 rounded-full blur-[100px]"></div>
        <div class="container mx-auto px-6 text-center">
            <a href="/videos" class="inline-flex flex-col items-center gap-8 group">
                <div class="w-20 h-20 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-academic-accent group-hover:bg-white group-hover:text-academic-dark transition-all duration-700 shadow-2xl relative overflow-hidden">
                    <div class="absolute inset-0 bg-academic-accent/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <i class="fa-solid fa-arrow-right-long text-2xl relative z-10 group-hover:translate-x-2 transition-transform duration-500"></i>
                </div>
                <div>
                   <span class="text-[10px] font-black tracking-[0.5em] text-slate-500 uppercase mb-4 block">Siguiente Sección</span>
                   <h2 class="font-serif text-5xl md:text-7xl font-black text-white leading-none tracking-tighter">Intervenciones en <br/><span class="text-slate-400 italic font-light">Vídeo</span></h2>
                </div>
            </a>
        </div>
    </section>

    <Footer />
  </main>
</Layout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.filter-btn');
        const searchInput = document.getElementById('bookSearch');

        function filterBooks() {
            const activeBtn = document.querySelector('.filter-btn.active');
            if (!activeBtn) return;
            
            const activeFilter = activeBtn.getAttribute('data-filter');
            const searchText = searchInput ? searchInput.value.toLowerCase() : '';
            const cards = document.querySelectorAll('.book-card');

            cards.forEach(card => {
                const category = card.getAttribute('data-category');
                const titleElement = card.querySelector('h4, h5');
                const title = titleElement ? titleElement.textContent.toLowerCase() : '';
                const metaText = Array.from(card.querySelectorAll('p, span')).map(el => el.textContent.toLowerCase()).join(' ');

                const matchesFilter = activeFilter === 'all' || category === activeFilter;
                const matchesSearch = title.includes(searchText) || metaText.includes(searchText);

                if (matchesFilter && matchesSearch) {
                    card.style.display = card.getAttribute('data-original-display') || (card.classList.contains('lg:grid-cols-12') ? 'grid' : 'block');
                } else {
                    if (!card.getAttribute('data-original-display')) {
                       card.setAttribute('data-original-display', window.getComputedStyle(card).display);
                    }
                    card.style.display = 'none';
                }
            });
        }

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => {
                    b.classList.remove('active', 'text-academic-accent', 'border-b-2', 'border-academic-accent');
                    b.classList.add('text-white/30');
                });
                btn.classList.add('active', 'text-academic-accent', 'border-b-2', 'border-academic-accent');
                btn.classList.remove('text-white/30');
                filterBooks();
            });
        });

        if (searchInput) {
            searchInput.addEventListener('input', filterBooks);
        }
    });
</script>

<style is:global>
    .perspective-1000 {
        perspective: 1000px;
    }
    .rotate-y-12 {
        transform: rotateY(-15deg);
    }
    .rotate-x-6 {
        transform: rotateX(5deg);
    }
    
    @keyframes pulse-slow {
        0%, 100% { opacity: 0.1; transform: scale(1); }
        50% { opacity: 0.15; transform: scale(1.1); }
    }
    .animate-pulse-slow {
        animation: pulse-slow 8s infinite ease-in-out;
    }

    main {
        font-family: 'Inter', system-ui, sans-serif;
    }
    h1, h2, h3, h4, h5 {
        font-family: 'Playfair Display', serif;
    }
</style>
