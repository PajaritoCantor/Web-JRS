---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Articulos from '../../components/Articulos.astro';
---

<Layout title="Artículos de Investigación | Jerónimo Ríos">
  <main class="w-full flex-grow bg-academic-dark min-h-screen">
    <!-- Hero Section para Artículos -->
    <section class="pt-40 pb-20 bg-academic-dark text-white border-b border-white/5 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-academic-accent/10 to-transparent"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-4xl">
                <span class="text-academic-accent text-[10px] font-black tracking-[0.5em] uppercase mb-8 block px-1 border-l-2 border-academic-accent">Producción Científica</span>
                <h1 class="font-serif text-6xl md:text-9xl font-black mb-10 leading-none tracking-tighter">Artículos <br/><span class="text-white/20 italic font-light">Académicos</span></h1>
                <p class="text-white/60 text-xl md:text-2xl leading-relaxed max-w-2xl font-light">
                    Explora la producción académica en revistas de impacto nacional e internacional sobre conflictos armados y relaciones internacionales.
                </p>
            </div>
        </div>
    </section>

    <!-- Filtros y Buscador (Consistente con libros.astro) -->
    <section class="py-10 bg-academic-dark/80 sticky top-0 z-50 backdrop-blur-xl border-b border-white/10">
        <div class="container mx-auto px-6 flex flex-wrap items-center justify-between gap-8">
            <div class="flex gap-8">
                <button class="text-academic-accent border-b-2 border-academic-accent pb-2 text-xs font-black tracking-widest uppercase">Recientes</button>
                <button class="text-white/30 hover:text-white transition-colors pb-2 text-xs font-black tracking-widest uppercase">Q1/Q2 Journals</button>
                <button class="text-white/30 hover:text-white transition-colors pb-2 text-xs font-black tracking-widest uppercase">Documentos</button>
            </div>
            <div class="relative w-full md:w-96 group">
                <input type="text" placeholder="BUSCAR POR PALABRACLAVE O REVISTA..." class="w-full bg-white/5 border border-white/10 rounded-full py-4 px-8 text-[11px] tracking-widest text-white placeholder:text-white/20 focus:outline-none focus:border-academic-accent/50 transition-all font-medium" />
                <i class="fa-solid fa-magnifying-glass absolute right-8 top-1/2 -translate-y-1/2 text-white/20 text-sm group-focus-within:text-academic-accent transition-colors"></i>
            </div>
        </div>
    </section>

    <!-- Lista de Artículos (Componente con Prop Dark) -->
    <Articulos showAllLink={false} dark={true} />

    <!-- Nota de Seguridad / Pie de Lista -->
    <section class="max-w-6xl mx-auto px-6 lg:px-8 pb-32">
        <aside class="rounded-2xl border border-white/5 bg-white/5 p-8 font-sans text-sm text-white/40 leading-relaxed backdrop-blur-sm">
            <div class="flex items-start gap-4">
                <i class="fa-solid fa-shield-halved text-academic-accent mt-1"></i>
                <p>
                    Nota de seguridad: Los enlaces externos a repositorios institucionales y revistas académicas son verificados periódicamente. Para reportar un enlace roto o acceso restringido, por favor contacte con el soporte técnico.
                </p>
            </div>
        </aside>
    </section>

    <Footer />
  </main>
</Layout>

<style>
    main {
        font-family: 'Inter', system-ui, sans-serif;
    }
    h1, h2, h3, h4, h5 {
        font-family: 'Playfair Display', serif;
    }
</style>
